<mah:MetroWindow  
    x:Class="FlowBloxSampleExtension.UI.Views.SampleWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:viewModel="clr-namespace:FlowBloxSampleExtension.UI.ViewModels"
    xmlns:res="clr-namespace:FlowBloxSampleExtension.UI.Resources"
    Title="{x:Static res:SampleWindow.Title}" 
    Height="300" Width="500"
    mc:Ignorable="d">

    <mah:MetroWindow.DataContext>
        <viewModel:SampleViewModel />
    </mah:MetroWindow.DataContext>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/FlowBlox.UICore;component/Views/MahAppMetroResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{x:Static res:SampleWindow.Description}" 
                   FontSize="16" 
                   TextWrapping="Wrap" 
                   VerticalAlignment="Center" 
                   HorizontalAlignment="Center"/>

        <Button Grid.Row="1" Content="{x:Static res:SampleWindow.CloseButton}" 
                IsCancel="True" 
                Margin="0,10,0,0"
                HorizontalAlignment="Right" Width="100"
                Click="CloseButton_Click"/>
    </Grid>
</mah:MetroWindow>
