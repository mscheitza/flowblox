<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="FlowBlox"
           Manufacturer="FlowBlox and contributors"
           Version="$(var.ProductVersion)"
           UpgradeCode="2E625FA9-C5D5-4E14-9A39-57A74E0B8CE6"
           InstallerVersion="500"
           Scope="perMachine"
           Language="1033">
    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Feature Id="MainFeature" Title="FlowBlox" Level="1">
      <ComponentGroupRef Id="FlowBloxFiles" />
      <ComponentRef Id="StartMenuShortcutComponent" />
    </Feature>
  </Package>

  <Fragment>
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="FlowBlox" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="FlowBlox" />
    </StandardDirectory>
  </Fragment>

  <Fragment>
    <DirectoryRef Id="ApplicationProgramsFolder">
      <Component Id="StartMenuShortcutComponent" Guid="*">
        <Shortcut Id="StartMenuShortcut"
                  Name="FlowBlox"
                  Description="FlowBlox"
                  Target="[INSTALLFOLDER]FlowBlox.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <RemoveFolder Id="RemoveApplicationProgramsFolder" On="uninstall" />
        <RegistryValue Root="HKCU"
                       Key="Software\FlowBlox"
                       Name="Installed"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </DirectoryRef>
  </Fragment>
</Wix>

