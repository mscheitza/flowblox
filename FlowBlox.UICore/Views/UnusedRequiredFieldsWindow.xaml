<mah:MetroWindow
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    x:Class="FlowBlox.UICore.Views.UnusedRequiredFieldsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:resources="clr-namespace:FlowBlox.UICore.Resources"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    mc:Ignorable="d"
    Title="{x:Static resources:UnusedRequiredFieldsWindow.Title}"
    Width="900"
    Height="620"
    WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/FlowBlox.UICore;component/Views/MahAppMetroResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel Margin="10">
        <Border Background="#FFEEEEEE" DockPanel.Dock="Top" Height="50" Padding="8">
            <StackPanel Orientation="Horizontal">
                <iconPacks:PackIconMaterial Kind="ClipboardAlertOutline"
                                            Width="28"
                                            Height="28"
                                            Margin="0,0,10,0"
                                            VerticalAlignment="Center"
                                            Foreground="DarkSlateGray" />
                <TextBlock Text="{x:Static resources:UnusedRequiredFieldsWindow.Header_Title}"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           FontSize="16" />
            </StackPanel>
        </Border>

        <Border Background="#FFF8E1"
                DockPanel.Dock="Top"
                Padding="12"
                CornerRadius="4"
                Margin="0,8,0,8">
            <TextBlock Text="{x:Static resources:UnusedRequiredFieldsWindow.Header_Description}"
                       Foreground="DarkSlateGray"
                       TextWrapping="Wrap" />
        </Border>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ToolBar Grid.Row="0" Margin="0,0,0,8">
                <Button x:Name="SelectAllButton"
                        Click="SelectAllButton_Click">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="CheckboxMarkedCircleOutline"
                                                        Width="14"
                                                        Height="14"
                                                        Margin="0,0,6,0"
                                                        Foreground="#2E7D32" />
                            <TextBlock Text="{x:Static resources:UnusedRequiredFieldsWindow.Toolbar_SelectAll}" />
                        </StackPanel>
                    </Button.Content>
                </Button>

                <Button x:Name="DeselectAllButton"
                        Margin="6,0,0,0"
                        Click="DeselectAllButton_Click">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="CheckboxBlankCircleOutline"
                                                        Width="14"
                                                        Height="14"
                                                        Margin="0,0,6,0"
                                                        Foreground="#B22222" />
                            <TextBlock Text="{x:Static resources:UnusedRequiredFieldsWindow.Toolbar_DeselectAll}" />
                        </StackPanel>
                    </Button.Content>
                </Button>
            </ToolBar>

            <ListView Grid.Row="1"
                      ItemsSource="{Binding FieldRows}">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Width="70">
                            <GridViewColumn.Header>
                                <CheckBox Content="{x:Static resources:UnusedRequiredFieldsWindow.Column_Select}"
                                          IsThreeState="True"
                                          Checked="SelectAllCheckBox_Checked"
                                          Unchecked="SelectAllCheckBox_Unchecked" />
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="{x:Static resources:UnusedRequiredFieldsWindow.Column_FieldName}"
                                        DisplayMemberBinding="{Binding FieldName}"
                                        Width="220" />

                        <GridViewColumn Header="{x:Static resources:UnusedRequiredFieldsWindow.Column_QualifiedName}"
                                        DisplayMemberBinding="{Binding FullyQualifiedName}"
                                        Width="420" />

                        <GridViewColumn Header="{x:Static resources:UnusedRequiredFieldsWindow.Column_FieldType}"
                                        DisplayMemberBinding="{Binding FieldType}"
                                        Width="140" />
                    </GridView>
                </ListView.View>
            </ListView>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,10,0,0">
                <Button Margin="0,0,6,0"
                        IsCancel="True"
                        Click="BackButton_Click">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="ArrowLeft"
                                                        Width="14"
                                                        Height="14"
                                                        Margin="0,0,6,0"
                                                        Foreground="#555" />
                            <TextBlock Text="{x:Static resources:UnusedRequiredFieldsWindow.Button_Back}" />
                        </StackPanel>
                    </Button.Content>
                </Button>

                <Button x:Name="ContinueButton"
                        IsDefault="True"
                        Click="ContinueButton_Click">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Check"
                                                        Width="14"
                                                        Height="14"
                                                        Margin="0,0,6,0"
                                                        Foreground="#2E7D32" />
                            <TextBlock x:Name="ContinueButtonText" />
                        </StackPanel>
                    </Button.Content>
                </Button>
            </StackPanel>
        </Grid>
    </DockPanel>
</mah:MetroWindow>
