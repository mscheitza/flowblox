<mah:MetroWindow
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    x:Class="FlowBlox.UICore.Views.ManageInputFilesWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModel="clr-namespace:FlowBlox.UICore.ViewModels"
    xmlns:converters="clr-namespace:FlowBlox.UICore.Converters"
    xmlns:resources="clr-namespace:FlowBlox.UICore.Resources"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    Title="{x:Static resources:ManageInputFilesWindow.Title}"
    Height="760"
    Width="1100"
    mc:Ignorable="d"
    WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/FlowBlox.UICore;component/Views/MahAppMetroResources.xaml" />
                <ResourceDictionary Source="/FlowBlox.UICore;component/Views/Styles/FlowBloxCustomStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
            <converters:EnumDisplayNameConverter x:Key="EnumDisplayNameConverter"/>

            <Style x:Key="ManageInputFiles.Icon.Open"
                   TargetType="{x:Type iconPacks:PackIconMaterial}"
                   BasedOn="{StaticResource FlowBlox.ToolbarIconBase}">
                <Setter Property="Foreground" Value="#2F6DB3"/>
            </Style>

            <Style x:Key="ManageInputFiles.Icon.Create"
                   TargetType="{x:Type iconPacks:PackIconMaterial}"
                   BasedOn="{StaticResource FlowBlox.ToolbarIconBase}">
                <Setter Property="Foreground" Value="#2E8B57"/>
            </Style>

            <Style x:Key="ManageInputFiles.Icon.Upload"
                   TargetType="{x:Type iconPacks:PackIconMaterial}"
                   BasedOn="{StaticResource FlowBlox.ToolbarIconBase}">
                <Setter Property="Foreground" Value="#1F8A8A"/>
            </Style>

            <Style x:Key="ManageInputFiles.Icon.Download"
                   TargetType="{x:Type iconPacks:PackIconMaterial}"
                   BasedOn="{StaticResource FlowBlox.ToolbarIconBase}">
                <Setter Property="Foreground" Value="#3A6EA5"/>
            </Style>

            <Style x:Key="ManageInputFiles.Icon.Locate"
                   TargetType="{x:Type iconPacks:PackIconMaterial}"
                   BasedOn="{StaticResource FlowBlox.ToolbarIconBase}">
                <Setter Property="Foreground" Value="#5C6B73"/>
            </Style>

            <Style x:Key="ManageInputFiles.Icon.Delete"
                   TargetType="{x:Type iconPacks:PackIconMaterial}"
                   BasedOn="{StaticResource FlowBlox.ToolbarIconBase}">
                <Setter Property="Foreground" Value="#C94F4F"/>
            </Style>
            
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel Margin="10">

        <!-- Header -->
        <Border Background="#FFEEEEEE"
                DockPanel.Dock="Top"
                Height="50"
                Padding="8">
            <StackPanel Orientation="Horizontal">
                <iconPacks:PackIconMaterial Kind="FileDocumentMultipleOutline"
                                            Width="30"
                                            Height="30"
                                            Margin="0,0,10,0"
                                            VerticalAlignment="Center"
                                            Foreground="DarkSlateGray"/>
                <TextBlock Text="{x:Static resources:ManageInputFilesWindow.Header_Title_Main}"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           FontSize="16"/>
            </StackPanel>
        </Border>

        <!-- Description -->
        <Border Background="#EDF3F9"
                DockPanel.Dock="Top"
                Padding="12"
                CornerRadius="4"
                Margin="0,8,0,10">
            <StackPanel>
                <TextBlock Text="{x:Static resources:ManageInputFilesWindow.Header_Description_Main}"
                           FontWeight="UltraLight"
                           Foreground="DarkSlateGray"
                           TextWrapping="Wrap"/>
                <TextBlock Margin="0,8,0,0"
                           Text="{Binding ProjectInputDirectory}"
                           FontWeight="SemiBold"
                           Foreground="#3A6EA5"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <ToolBar Grid.Row="0" VerticalAlignment="Center">

                <Button Command="{Binding OpenInputDirectoryCommand}"
                        ToolTip="{x:Static resources:ManageInputFilesWindow.Tooltip_OpenInputDirectory}">
                    <iconPacks:PackIconMaterial Kind="FolderOpenOutline"
                                    Style="{StaticResource ManageInputFiles.Icon.Open}"/>
                </Button>

                <Separator/>

                <Button Command="{Binding CreateInputFileCommand}"
                        ToolTip="{x:Static resources:ManageInputFilesWindow.Tooltip_CreateTemplate}">
                    <iconPacks:PackIconMaterial Kind="FilePlusOutline"
                                    Style="{StaticResource ManageInputFiles.Icon.Create}"/>
                </Button>

                <Button Command="{Binding UploadInputFileCommand}"
                        IsEnabled="{Binding IsInputFileSelected}"
                        Margin="6,0,0,0"
                        ToolTip="{x:Static resources:ManageInputFilesWindow.Tooltip_UploadTemplate}">
                    <iconPacks:PackIconMaterial Kind="UploadOutline"
                                    Style="{StaticResource ManageInputFiles.Icon.Upload}"/>
                </Button>

                <Button Command="{Binding DownloadInputFileCommand}"
                        IsEnabled="{Binding IsInputFileSelected}"
                        Margin="6,0,0,0"
                        ToolTip="{x:Static resources:ManageInputFilesWindow.Tooltip_DownloadTemplate}">
                    <iconPacks:PackIconMaterial Kind="DownloadOutline"
                                    Style="{StaticResource ManageInputFiles.Icon.Download}"/>
                </Button>

                <Button Command="{Binding OpenInputFileInExplorerCommand}"
                        IsEnabled="{Binding IsInputFileSelected}"
                        Margin="6,0,0,0"
                        ToolTip="{x:Static resources:ManageInputFilesWindow.Tooltip_OpenTemplateInExplorer}">
                    <iconPacks:PackIconMaterial Kind="FolderSearchOutline"
                                    Style="{StaticResource ManageInputFiles.Icon.Locate}"/>
                </Button>

                <Button Command="{Binding ExecuteInputFileCommandCommand}"
                        IsEnabled="{Binding IsInputFileSelected}"
                        Margin="6,0,0,0"
                        ToolTip="{x:Static resources:ManageInputFilesWindow.Tooltip_ExecuteInputFileCommand}">
                    <iconPacks:PackIconMaterial Kind="PlayCircleOutline"
                                    Style="{StaticResource ManageInputFiles.Icon.Create}"/>
                </Button>

                <Button Command="{Binding RemoveInputFileCommand}"
                        IsEnabled="{Binding IsInputFileSelected}"
                        Margin="10,0,0,0"
                        ToolTip="{x:Static resources:ManageInputFilesWindow.Tooltip_RemoveTemplate}">
                    <iconPacks:PackIconMaterial Kind="DeleteOutline"
                                    Style="{StaticResource ManageInputFiles.Icon.Delete}"/>
                </Button>

            </ToolBar>

            <!-- Grid -->
            <DataGrid x:Name="InputFilesGrid"
                      Grid.Row="1"
                      ItemsSource="{Binding InputFiles}"
                      SelectedItem="{Binding SelectedInputFile}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="False"
                      Margin="0,10,0,0">
                <DataGrid.Columns>

                    <!-- Read-only "InputDir" column to make the base directory explicit -->
                    <DataGridTextColumn Header="{x:Static resources:ManageInputFilesWindow.Header_InputDir}"
                                        Binding="{Binding DataContext.ProjectInputDirectory, RelativeSource={RelativeSource AncestorType=Window}}"
                                        IsReadOnly="True"
                                        Width="*"/>

                    <DataGridTextColumn Header="{x:Static resources:ManageInputFilesWindow.Header_RelativePath}"
                                        Binding="{Binding RelativePath, UpdateSourceTrigger=PropertyChanged}"
                                        Width="2*"/>

                    <DataGridTextColumn Header="{x:Static resources:ManageInputFilesWindow.Header_FileName}"
                                        Binding="{Binding FileName}"
                                        IsReadOnly="True"
                                        Width="*"/>

                    <DataGridTextColumn Header="{x:Static resources:ManageInputFilesWindow.Header_Size}"
                                        Binding="{Binding SizeBytes}"
                                        IsReadOnly="True"
                                        Width="120"/>

                    <DataGridTemplateColumn Header="{x:Static resources:ManageInputFilesWindow.Header_Command}"
                                            Width="2.3*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Command}" TextWrapping="Wrap"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <DockPanel LastChildFill="True">
                                    <Button DockPanel.Dock="Right"
                                            Width="28"
                                            Height="24"
                                            Margin="6,0,0,0"
                                            ToolTip="{x:Static resources:ManageInputFilesWindow.Tooltip_InsertInputFilePlaceholder}"
                                            Click="InsertInputFilePlaceholderButton_Click">
                                        <iconPacks:PackIconMaterial Kind="Variable"
                                                                    Width="14"
                                                                    Height="14"
                                                                    Foreground="#2F6DB3"/>
                                    </Button>
                                    <TextBox Text="{Binding Command, UpdateSourceTrigger=PropertyChanged}"
                                             VerticalContentAlignment="Center"
                                             PreviewKeyDown="CommandTextBox_PreviewKeyDown"/>
                                </DockPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <DataGridCheckBoxColumn Header="{x:Static resources:ManageInputFilesWindow.Header_ExecuteBeforeRuntime}"
                                            Binding="{Binding ExecuteBeforeRuntime, UpdateSourceTrigger=PropertyChanged}"
                                            Width="180"/>

                    <DataGridTemplateColumn Header="{x:Static resources:ManageInputFilesWindow.Header_SyncMode}"
                                            Width="190">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding SyncMode, Converter={StaticResource EnumDisplayNameConverter}}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding DataContext.SyncModes, RelativeSource={RelativeSource AncestorType=Window}}"
                                          SelectedItem="{Binding SyncMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Converter={StaticResource EnumDisplayNameConverter}}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>

            <!-- Bottom buttons -->
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,10,0,0">
                <Button Command="{Binding CloseCommand}" IsCancel="True">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Close" Margin="0,0,5,0"/>
                            <TextBlock Text="{x:Static resources:ManageInputFilesWindow.Button_Close}"/>
                        </StackPanel>
                    </Button.Content>
                </Button>
            </StackPanel>

        </Grid>
    </DockPanel>
</mah:MetroWindow>
