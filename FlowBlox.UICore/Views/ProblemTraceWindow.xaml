<mah:MetroWindow  
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    x:Class="FlowBlox.UICore.Views.ProblemTraceWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModel="clr-namespace:FlowBlox.UICore.ViewModels"
    xmlns:converters="clr-namespace:FlowBlox.UICore.Converters"
    xmlns:resources="clr-namespace:FlowBlox.UICore.Resources"
    Title="{x:Static resources:ProblemTraceWindow.Title}" 
    Height="800" Width="1000"
    mc:Ignorable="d">

    <Window.DataContext>
        <viewModel:ProblemTraceViewModel />
    </Window.DataContext>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/FlowBlox.UICore;component/Views/MahAppMetroResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <converters:TruncateConverter x:Key="TruncateConverter"/>
            <converters:ExceptionToStringConverter x:Key="ExceptionToStringConverter" />
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="10">
            <Label Content="{x:Static resources:ProblemTraceWindow.Label_Timestamp}" />
            <TextBox Text="{Binding SelectedProblemTrace.Timestamp}" IsReadOnly="True" Margin="0,0,0,5"/>

            <Label Content="{x:Static resources:ProblemTraceWindow.Label_Name}" />
            <TextBox Text="{Binding SelectedProblemTrace.Name}" IsReadOnly="True" Margin="0,0,0,5"/>

            <Label Content="{x:Static resources:ProblemTraceWindow.Label_Criticality}" />
            <TextBox Text="{Binding SelectedProblemTrace.Criticality}" IsReadOnly="True" Margin="0,0,0,5"/>

            <Label Content="{x:Static resources:ProblemTraceWindow.Label_Message}" />
            <TextBox Text="{Binding SelectedProblemTrace.Message}" IsReadOnly="True" Margin="0,0,0,5"/>

            <StackPanel>
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedProblemTrace.Exception}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SelectedProblemTrace.Exception}" Value="">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <Label Content="{x:Static resources:ProblemTraceWindow.Label_Exception}" />
                <TextBox Text="{Binding SelectedProblemTrace.Exception, Converter={StaticResource ExceptionToStringConverter}}" 
                         IsReadOnly="True" Margin="0,0,0,5" AcceptsReturn="True" TextWrapping="Wrap" Height="100"/>
            </StackPanel>
        </StackPanel>

        <ScrollViewer Grid.Row="1" Margin="10">
            <StackPanel>
                <Label Content="{x:Static resources:ProblemTraceWindow.Label_FieldValues}" />
                <DataGrid AutoGenerateColumns="False" ItemsSource="{Binding SelectedProblemTrace.FieldValues}" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{x:Static resources:ProblemTraceWindow.Column_FullyQualifiedName}" Binding="{Binding FullyQualifiedName}" Width="30*"/>
                        <DataGridTextColumn Header="{x:Static resources:ProblemTraceWindow.Column_Value}" Binding="{Binding Value, Converter={StaticResource TruncateConverter}}" Width="70*"/>
                        <DataGridTemplateColumn Header="{x:Static resources:ProblemTraceWindow.Column_Details}" Width="10*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="..." Command="{Binding DataContext.OpenEditorCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</mah:MetroWindow>
