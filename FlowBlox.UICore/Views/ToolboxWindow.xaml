<mah:MetroWindow
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    x:Class="FlowBlox.UICore.Views.ToolboxWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModel="clr-namespace:FlowBlox.UICore.ViewModels" 
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:resources="clr-namespace:FlowBlox.UICore.Resources"
    Title="{x:Static resources:ToolboxWindow.Title}"
    Height="500"
    Width="900"
    WindowStartupLocation="CenterOwner">

    <Window.DataContext>
        <viewModel:ToolboxWindowViewModel />
    </Window.DataContext>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/FlowBlox.UICore;component/Views/MahAppMetroResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="1.5*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="0" HorizontalAlignment="Left">
            <Button Command="{Binding AddCommand}" ToolTip="{x:Static resources:ToolboxWindow.ToolTip_Add}" Margin="5">
                <iconPacks:PackIconModern Kind="Add" />
            </Button>
            <Button Command="{Binding RemoveCommand}" ToolTip="{x:Static resources:ToolboxWindow.ToolTip_Remove}" Margin="5" IsEnabled="{Binding CanRemove}">
                <iconPacks:PackIconModern Kind="Delete" />
            </Button>
        </StackPanel>

        <!-- Toolbox Scope ComboBox -->
        <ComboBox Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right" Width="200" 
                  ItemsSource="{Binding ToolboxScopes}" 
                  SelectedItem="{Binding ToolboxScope, Mode=TwoWay}" 
                  Margin="5">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding}" />
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <!-- List View -->
        <ListView Grid.Row="1" Grid.Column="0" ItemsSource="{Binding ToolboxElements}" SelectedItem="{Binding SelectedToolboxElement, Mode=TwoWay}">
            <i:Interaction.Triggers>
                <i:EventTrigger EventName="MouseDoubleClick">
                    <i:CallMethodAction MethodName="SelectToolboxElement" TargetObject="{Binding}" />
                </i:EventTrigger>
            </i:Interaction.Triggers>
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="{x:Static resources:ToolboxWindow.GridView_Column_Type}" DisplayMemberBinding="{Binding ToolboxCategoryDisplayName}" Width="Auto" />
                    <GridViewColumn Header="{x:Static resources:ToolboxWindow.GridView_Column_Name}" DisplayMemberBinding="{Binding Name}" Width="Auto" />
                </GridView>
            </ListView.View>
        </ListView>

        <!-- Detail View -->
        <Grid Grid.Row="1" Grid.Column="1" Visibility="{Binding DetailViewVisibility}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="{x:Static resources:ToolboxWindow.Label_ToolboxType}" Margin="5"/>
            <ComboBox Grid.Row="1"
                      ItemsSource="{Binding ToolboxTypes}"
                      DisplayMemberPath="DisplayName"
                      SelectedValuePath="Name"
                      SelectedValue="{Binding SelectedToolboxElement.ToolboxCategory}"
                      Margin="5"/>

            <TextBlock Grid.Row="2" Text="{x:Static resources:ToolboxWindow.Label_Name}" Margin="5"/>
            <TextBox Grid.Row="3" Text="{Binding SelectedToolboxElement.Name, UpdateSourceTrigger=PropertyChanged}" Margin="5"/>

            <TextBlock Grid.Row="4" Text="{x:Static resources:ToolboxWindow.Label_Content}" Margin="5"/>
            <TextBox Grid.Row="5" Text="{Binding SelectedToolboxElement.Content, UpdateSourceTrigger=PropertyChanged}" Margin="5" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

            <Button Grid.Row="6" Content="{x:Static resources:ToolboxWindow.Button_Save}" Command="{Binding SaveCommand}" HorizontalAlignment="Right" Margin="5" IsEnabled="{Binding DataContext.CanSave}"/>
        </Grid>

        <!-- No Items Found Message -->
        <StackPanel Orientation="Horizontal" Grid.Row="2" Grid.Column="0">
            <iconPacks:PackIconModern Kind="Information" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="{Binding NoToolboxElementsFoundVisibility}" />
            <TextBlock Text="{x:Static resources:ToolboxWindow.Message_NoToolboxElementsFound}" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="{Binding NoToolboxElementsFoundVisibility}" />
        </StackPanel>

        <!-- Bottom Panel for Selection Mode -->
        <StackPanel Orientation="Horizontal" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" HorizontalAlignment="Right" Visibility="{Binding IsSelectionMode, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Button Content="{x:Static resources:ToolboxWindow.Button_Select}" Command="{Binding SelectCommand}" Margin="5"/>
        </StackPanel>
    </Grid>
</mah:MetroWindow>
