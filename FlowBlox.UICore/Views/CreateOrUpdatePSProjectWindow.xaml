<mah:MetroWindow
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    x:Class="FlowBlox.UICore.Views.CreateOrUpdatePSProjectWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:resources="clr-namespace:FlowBlox.UICore.Resources"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    Title="{x:Static resources:CreateOrUpdatePSProjectWindow.Title}"
    Height="520"
    Width="760"
    WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/FlowBlox.UICore;component/Views/MahAppMetroResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel Margin="10">

        <!-- Header -->
        <Border Background="#FFEEEEEE" DockPanel.Dock="Top" Height="50" Padding="8">
            <StackPanel Orientation="Horizontal">
                <iconPacks:PackIconMaterial Kind="CloudUploadOutline"
                                            Width="32"
                                            Height="32"
                                            Margin="0,0,10,0"
                                            VerticalAlignment="Center"
                                            Foreground="DarkSlateGray"/>
                <TextBlock Text="{x:Static resources:CreateOrUpdatePSProjectWindow.Header_Title}"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           FontSize="16" />
            </StackPanel>
        </Border>

        <!-- Description -->
        <Border Background="#EDF3F9"
                DockPanel.Dock="Top"
                Padding="12"
                CornerRadius="4"
                Margin="0,8,0,8">
            <TextBlock Text="{x:Static resources:CreateOrUpdatePSProjectWindow.Header_Description}"
                       FontWeight="UltraLight"
                       Foreground="DarkSlateGray"
                       TextWrapping="Wrap" />
        </Border>

        <!-- Content -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Left -->
            <StackPanel Grid.Column="0" Grid.Row="0" Margin="10">

                <Label Content="{x:Static resources:CreateOrUpdatePSProjectWindow.Label_ProjectGuid}" Margin="0,5,0,0"/>
                <TextBox Text="{Binding ProjectGuid}" IsReadOnly="True" />

                <Label HorizontalAlignment="Left" Margin="0,5,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{x:Static resources:CreateOrUpdatePSProjectWindow.Label_ProjectName}" />
                        <iconPacks:PackIconMaterial Kind="Asterisk"
                                                    Width="9"
                                                    Height="9"
                                                    Margin="6,1,0,0"
                                                    Foreground="IndianRed"
                                                    VerticalAlignment="Center"/>
                    </StackPanel>
                </Label>
                <TextBox Text="{Binding ProjectName, UpdateSourceTrigger=PropertyChanged}"
                         mah:TextBoxHelper.Watermark="{x:Static resources:CreateOrUpdatePSProjectWindow.Placeholder_ProjectName}" />

                <Label Content="{x:Static resources:CreateOrUpdatePSProjectWindow.Label_Visibility}" Margin="0,5,0,0"/>
                <ComboBox SelectedValue="{Binding Visibility}"
                          SelectedValuePath="Tag">
                    <ComboBoxItem Content="{x:Static resources:CreateOrUpdatePSProjectWindow.Visibility_Private}" Tag="Private" />
                    <ComboBoxItem Content="{x:Static resources:CreateOrUpdatePSProjectWindow.Visibility_Public}" Tag="Public" />
                </ComboBox>
            </StackPanel>

            <!-- Right -->
            <StackPanel Grid.Column="1" Grid.Row="0" Margin="10">

                <Label HorizontalAlignment="Left" Margin="0,5,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{x:Static resources:CreateOrUpdatePSProjectWindow.Label_ProjectDescription}" />
                        <iconPacks:PackIconMaterial Kind="Asterisk"
                                                    Width="9"
                                                    Height="9"
                                                    Margin="6,1,0,0"
                                                    Foreground="IndianRed"
                                                    VerticalAlignment="Center"/>
                    </StackPanel>
                </Label>
                <TextBox Text="{Binding ProjectDescription, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Height="140"
                         mah:TextBoxHelper.Watermark="{x:Static resources:CreateOrUpdatePSProjectWindow.Placeholder_ProjectDescription}" />

                <Label Content="{x:Static resources:CreateOrUpdatePSProjectWindow.Label_CreatedAt}" Margin="0,5,0,0"/>
                <TextBox Text="{Binding CreatedAtText}" IsReadOnly="True" />

                <Label Content="{x:Static resources:CreateOrUpdatePSProjectWindow.Label_UpdatedAt}" Margin="0,5,0,0"/>
                <TextBox Text="{Binding UpdatedAtText}" IsReadOnly="True" />
            </StackPanel>

            <TextBlock Grid.ColumnSpan="2" Grid.Row="1"
                       Text="{Binding ErrorText}"
                       Foreground="Red"
                       Margin="0,5,0,0"
                       TextWrapping="Wrap" />

            <StackPanel Grid.ColumnSpan="2" Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,10,0,0">
                <Button Content="{x:Static resources:CreateOrUpdatePSProjectWindow.Button_Cancel}"
                        Padding="5,0,5,0"
                        Margin="5,0,5,0"
                        Command="{Binding CloseCommand}" />
                <Button Content="{x:Static resources:CreateOrUpdatePSProjectWindow.Button_Save}"
                        Padding="5,0,5,0"
                        Command="{Binding SaveCommand}"
                        IsEnabled="{Binding CanSave}" />
            </StackPanel>
        </Grid>
    </DockPanel>
</mah:MetroWindow>
