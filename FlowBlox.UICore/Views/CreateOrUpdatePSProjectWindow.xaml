<mah:MetroWindow
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    x:Class="FlowBlox.UICore.Views.CreateOrUpdatePSProjectWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:resources="clr-namespace:FlowBlox.UICore.Resources"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:views="clr-namespace:FlowBlox.UICore.Views"
    xmlns:converters="clr-namespace:FlowBlox.UICore.Converters"
    Title="{x:Static resources:CreateOrUpdatePSProjectWindow.Title}"
    Height="570"
    Width="760"
    WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/FlowBlox.UICore;component/Views/MahAppMetroResources.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel Margin="10">

        <!-- Header -->
        <Border Background="#FFEEEEEE" DockPanel.Dock="Top" Height="50" Padding="8">
            <StackPanel Orientation="Horizontal">
                <iconPacks:PackIconMaterial Kind="CloudUploadOutline"
                                            Width="32"
                                            Height="32"
                                            Margin="0,0,10,0"
                                            VerticalAlignment="Center"
                                            Foreground="DarkSlateGray"/>
                <TextBlock Text="{x:Static resources:CreateOrUpdatePSProjectWindow.Header_Title}"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           FontSize="16" />
            </StackPanel>
        </Border>

        <!-- Description -->
        <Border Background="#EDF3F9"
                DockPanel.Dock="Top"
                Padding="12"
                CornerRadius="4"
                Margin="0,8,0,8">
            <TextBlock Text="{x:Static resources:CreateOrUpdatePSProjectWindow.Header_Description}"
                       FontWeight="UltraLight"
                       Foreground="DarkSlateGray"
                       TextWrapping="Wrap" />
        </Border>

        <!-- Content -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Main (scrollable) -->
            <ScrollViewer Grid.Row="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          CanContentScroll="True">
                <Grid>
                    <TabControl SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">

                        <!-- Create new -->
                        <TabItem Header="{x:Static resources:CreateOrUpdatePSProjectWindow.Tab_CreateNewProject}">
                            <TabItem.HeaderTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="PlusBoxOutline"
                                                                    Width="16"
                                                                    Height="16"
                                                                    Margin="0,0,8,0"
                                                                    VerticalAlignment="Center"
                                                                    Foreground="#2E7D32"/>
                                        <TextBlock Text="{Binding}"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Padding="0,5"/>
                                    </StackPanel>
                                </DataTemplate>
                            </TabItem.HeaderTemplate>

                            <TabItem.ToolTip>
                                <TextBlock Text="{x:Static resources:CreateOrUpdatePSProjectWindow.Tooltip_Tab_CreateNewProject}"
                                           TextWrapping="Wrap"
                                           Width="320"/>
                            </TabItem.ToolTip>

                            <views:ProjectSpaceProjectFormControl />
                        </TabItem>

                        <!-- Update existing -->
                        <TabItem Header="{x:Static resources:CreateOrUpdatePSProjectWindow.Tab_UpdateExistingProject}"
                                 Visibility="{Binding ShowUpdateTab, Converter={StaticResource BoolToVisibilityConverter}}"
                                 IsEnabled="{Binding CanSelectUpdateTab}">
                            <TabItem.HeaderTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="CloudUploadOutline"
                                                                    Width="16"
                                                                    Height="16"
                                                                    Margin="0,0,8,0"
                                                                    VerticalAlignment="Center"
                                                                    Foreground="#3A6EA5"/>
                                        <TextBlock Text="{Binding}"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Padding="0,5"/>
                                    </StackPanel>
                                </DataTemplate>
                            </TabItem.HeaderTemplate>

                            <TabItem.ToolTip>
                                <TextBlock Text="{x:Static resources:CreateOrUpdatePSProjectWindow.Tooltip_Tab_UpdateExistingProject}"
                                           TextWrapping="Wrap"
                                           Width="320"/>
                            </TabItem.ToolTip>

                            <views:ProjectSpaceProjectFormControl />
                        </TabItem>

                    </TabControl>
                </Grid>
            </ScrollViewer>

            <!-- Error message (always visible) -->
            <TextBlock Grid.Row="1"
                       Text="{Binding ErrorText}"
                       Foreground="Red"
                       Margin="0,8,0,0"
                       TextWrapping="Wrap" />

            <!-- Footer buttons (always visible) -->
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,10,0,0">
                <Button Content="{x:Static resources:CreateOrUpdatePSProjectWindow.Button_Cancel}"
                        Padding="5,0,5,0"
                        Margin="5,0,5,0"
                        Command="{Binding CloseCommand}"
                        IsCancel="True"/>
                <Button Content="{x:Static resources:CreateOrUpdatePSProjectWindow.Button_Save}"
                        Padding="5,0,5,0"
                        Command="{Binding SaveCommand}"
                        IsEnabled="{Binding CanSave}"
                        IsDefault="True"/>
            </StackPanel>
        </Grid>
    </DockPanel>
</mah:MetroWindow>
