<mah:MetroWindow
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    x:Class="FlowBlox.UICore.Views.EditUserPropertiesWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:resources="clr-namespace:FlowBlox.UICore.Resources"
    xmlns:converters="clr-namespace:FlowBlox.UICore.Converters"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    Title="{x:Static resources:EditUserPropertiesWindow.Title}"
    Width="650"
    Height="520"
    WindowStartupLocation="CenterOwner"
    ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/FlowBlox.UICore;component/Views/MahAppMetroResources.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel Margin="10">

        <!-- Header -->
        <Border Background="#FFEEEEEE" DockPanel.Dock="Top" Height="50" Padding="8">
            <StackPanel Orientation="Horizontal">
                <iconPacks:PackIconMaterial Kind="AccountEditOutline"
                                            Width="32"
                                            Height="32"
                                            Margin="0,0,10,0"
                                            VerticalAlignment="Center"
                                            Foreground="DarkSlateGray"/>
                <TextBlock Text="{x:Static resources:EditUserPropertiesWindow.Header_Title}"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           FontSize="16" />
            </StackPanel>
        </Border>

        <!-- Description -->
        <Border Background="#EDF3F9"
                DockPanel.Dock="Top"
                Padding="12"
                CornerRadius="4"
                Margin="0,8,0,8">
            <TextBlock Text="{x:Static resources:EditUserPropertiesWindow.Header_Description}"
                       FontWeight="UltraLight"
                       Foreground="DarkSlateGray"
                       TextWrapping="Wrap" />
        </Border>

        <!-- Content + Error Footer + Buttons -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Content (scrollable) -->
            <ScrollViewer Grid.Row="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Margin="0,0,0,6">

                <Grid Margin="10,0,10,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- First Name -->
                    <Label Grid.Row="0"
                           Content="{x:Static resources:EditUserPropertiesWindow.Label_FirstName}"
                           HorizontalAlignment="Left"
                           Margin="0,5,0,0" />
                    <TextBox Grid.Row="1"
                             Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}"
                             mah:TextBoxHelper.Watermark="{x:Static resources:EditUserPropertiesWindow.Placeholder_FirstName}" />

                    <!-- Last Name -->
                    <Label Grid.Row="2"
                           Content="{x:Static resources:EditUserPropertiesWindow.Label_LastName}"
                           HorizontalAlignment="Left"
                           Margin="0,10,0,0" />
                    <TextBox Grid.Row="3"
                             Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}"
                             mah:TextBoxHelper.Watermark="{x:Static resources:EditUserPropertiesWindow.Placeholder_LastName}" />

                    <!-- Username -->
                    <Label Grid.Row="4"
                           Content="{x:Static resources:EditUserPropertiesWindow.Label_UserName}"
                           HorizontalAlignment="Left"
                           Margin="0,10,0,0" />
                    <TextBox Grid.Row="5"
                             Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}"
                             mah:TextBoxHelper.Watermark="{x:Static resources:EditUserPropertiesWindow.Placeholder_UserName}"
                             ToolTip="{x:Static resources:EditUserPropertiesWindow.Tooltip_UserName}" />
                </Grid>
            </ScrollViewer>

            <!-- Error footer -->
            <Border Grid.Row="1"
                    Background="#FFFCE8E8"
                    BorderBrush="#FFE6A3A3"
                    BorderThickness="1"
                    Padding="12"
                    CornerRadius="4"
                    Margin="0,6,0,0"
                    Visibility="{Binding ErrorText, Converter={StaticResource NullToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <iconPacks:PackIconMaterial Kind="AlertCircleOutline"
                                                Width="18"
                                                Height="18"
                                                Margin="0,2,10,0"
                                                Foreground="#FF8A1F1F"
                                                VerticalAlignment="Top"/>

                    <TextBlock Grid.Column="1"
                               Text="{Binding ErrorText}"
                               FontWeight="UltraLight"
                               Foreground="#FF8A1F1F"
                               TextWrapping="Wrap" />
                </Grid>
            </Border>

            <!-- Buttons -->
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,10,0,0">
                <Button Content="{x:Static resources:EditUserPropertiesWindow.Button_Back}"
                        Padding="5,0,5,0"
                        Margin="0,0,6,0"
                        Command="{Binding CloseCommand}"
                        IsCancel="True"/>
                <Button Content="{x:Static resources:EditUserPropertiesWindow.Button_Save}"
                        Padding="5,0,5,0"
                        Command="{Binding SaveCommand}"
                        IsEnabled="{Binding CanSave}"
                        IsDefault="True"/>
            </StackPanel>
        </Grid>
    </DockPanel>
</mah:MetroWindow>
