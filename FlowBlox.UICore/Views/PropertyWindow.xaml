<mah:MetroWindow
    x:Class="FlowBlox.UICore.Views.PropertyWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="clr-namespace:FlowBlox.UICore.Views"
    xmlns:viewModel="clr-namespace:FlowBlox.UICore.ViewModels.PropertyView"
    xmlns:converters="clr-namespace:FlowBlox.UICore.Converters"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:resources="clr-namespace:FlowBlox.UICore.Resources"
    mc:Ignorable="d"
    Title="{Binding HeaderTitle}"
    Height="600"
    Width="800">

    <Window.DataContext>
        <viewModel:PropertyWindowViewModel />
    </Window.DataContext>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/FlowBlox.UICore;component/Views/MahAppMetroResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        </ResourceDictionary>
    </Window.Resources>
    
    <DockPanel>

        <!-- Header -->
        <Border Background="#FFEEEEEE" DockPanel.Dock="Top" Height="50" Padding="8">
            <StackPanel Orientation="Horizontal">
                <Image Source="{Binding HeaderIcon}" Width="32" Height="32" Margin="0,0,10,0"/>
                <TextBlock Text="{Binding HeaderTitle}" FontWeight="Bold" VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Description -->
        <Border Background="#EDF3F9"
        DockPanel.Dock="Top"
        Padding="12"
        CornerRadius="4"
        Visibility="{Binding HeaderDescription, Converter={StaticResource NullToVisibilityConverter}}">
            <TextBlock Text="{Binding HeaderDescription}"
               FontWeight="UltraLight"
               Foreground="DarkSlateGray"
               TextWrapping="Wrap"
               TextTrimming="CharacterEllipsis" />
        </Border>

        <!-- Operations -->
        <Border Background="#DDE7F3"
            DockPanel.Dock="Top"
            BorderBrush="#CCC"
            BorderThickness="0,1,0,1"
            Padding="6,4,6,4"
            Margin="0,0,0,0">
            <ItemsControl ItemsSource="{Binding UIActions}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Command="{Binding Command}"
                            IsEnabled="{Binding IsEnabled}"
                            ToolTip="{Binding DisplayName}"
                            Margin="3,0"
                            Padding="6,3"
                            MinWidth="80"
                            Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="CogOutline"
                                                    Width="14"
                                                    Height="14"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,5,0"/>
                                <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Bottom" Margin="10">

            <!-- Back -->
            <Button Margin="5" Command="{Binding CancelCommand}" IsCancel="True">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="ArrowLeft"
                                        Width="14"
                                        Height="14"
                                        VerticalAlignment="Center"
                                        Margin="0,0,5,0"/>
                    <TextBlock Text="{x:Static resources:PropertyWindow.Back}" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- SaveWithoutVerification -->
            <Button Margin="5"
                Command="{Binding SaveWithoutVerificationCommand}"
                Visibility="{Binding DisplaySaveButton, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="ContentSaveEdit"
                                        Width="14"
                                        Height="14"
                                        VerticalAlignment="Center"
                                        Margin="0,0,5,0"/>
                    <TextBlock Text="{x:Static resources:PropertyWindow.SaveWithoutVerification}" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Save -->
            <Button Margin="5"
                Command="{Binding SaveCommand}"
                Visibility="{Binding DisplaySaveButton, Converter={StaticResource BoolToVisibilityConverter}}"
                IsDefault="True">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="ContentSave"
                                        Width="14"
                                        Height="14"
                                        VerticalAlignment="Center"
                                        Margin="0,0,5,0"/>
                    <TextBlock Text="{x:Static resources:PropertyWindow.Save}" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>
        
        <!-- PropertyView Embedding -->
        <views:PropertyView DataContext="{Binding PropertyViewModel}" />

    </DockPanel>
</mah:MetroWindow>