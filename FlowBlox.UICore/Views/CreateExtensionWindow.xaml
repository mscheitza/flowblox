<mah:MetroWindow
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    x:Class="FlowBlox.UICore.Views.CreateExtensionWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:resources="clr-namespace:FlowBlox.UICore.Resources"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    Title="{x:Static resources:CreateExtensionWindow.Title}"
    Height="520"
    Width="760"
    WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/FlowBlox.UICore;component/Views/MahAppMetroResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel Margin="10">
        <Border Background="#FFEEEEEE" DockPanel.Dock="Top" Height="50" Padding="8">
            <StackPanel Orientation="Horizontal">
                <iconPacks:PackIconMaterial Kind="PuzzleOutline"
                                            Width="30"
                                            Height="30"
                                            Margin="0,0,10,0"
                                            VerticalAlignment="Center"
                                            Foreground="DarkSlateGray"/>
                <TextBlock Text="{x:Static resources:CreateExtensionWindow.Header_Title}"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           FontSize="16"/>
            </StackPanel>
        </Border>

        <Border Background="#EDF3F9"
                DockPanel.Dock="Top"
                Padding="12"
                CornerRadius="4"
                Margin="0,8,0,8">
            <TextBlock Text="{x:Static resources:CreateExtensionWindow.Header_Description}"
                       FontWeight="UltraLight"
                       Foreground="DarkSlateGray"
                       TextWrapping="Wrap"/>
        </Border>

        <ToolBar DockPanel.Dock="Top" Margin="0,0,0,8">
            <Button Command="{Binding ExtractMetadataCommand}"
                    ToolTip="{x:Static resources:CreateExtensionWindow.Toolbar_ExtractMetadata_Tooltip}">
                <Button.Content>
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="FolderSearchOutline" Margin="0,0,5,0"/>
                        <TextBlock Text="{x:Static resources:CreateExtensionWindow.Toolbar_ExtractMetadata}"/>
                    </StackPanel>
                </Button.Content>
            </Button>
        </ToolBar>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                       Text="{x:Static resources:CreateExtensionWindow.Hint_Metadata}"
                       Foreground="Gray"
                       Margin="0,0,0,10"
                       TextWrapping="Wrap"/>

            <TextBlock Grid.Row="1" Grid.Column="0"
                       VerticalAlignment="Center"
                       Text="{x:Static resources:CreateExtensionWindow.Label_Name}"/>
            <TextBox Grid.Row="1" Grid.Column="1"
                     mah:TextBoxHelper.Watermark="{x:Static resources:CreateExtensionWindow.Watermark_Name}"
                     Text="{Binding ExtensionName, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Row="2" Grid.Column="0"
                       Margin="0,10,0,0"
                       VerticalAlignment="Top"
                       Text="{x:Static resources:CreateExtensionWindow.Label_Description}"/>
            <TextBox Grid.Row="2" Grid.Column="1"
                     Margin="0,10,0,0"
                     MinHeight="70"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     mah:TextBoxHelper.Watermark="{x:Static resources:CreateExtensionWindow.Watermark_Description}"
                     Text="{Binding ExtensionDescription, UpdateSourceTrigger=PropertyChanged}"/>

            <StackPanel Grid.Row="4"
                        Grid.ColumnSpan="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,20,0,0">
                <Button Content="{x:Static resources:CreateExtensionWindow.Button_Cancel}"
                        Command="{Binding CancelCommand}"
                        Margin="0,0,10,0"
                        IsCancel="True"/>
                <Button Content="{x:Static resources:CreateExtensionWindow.Button_Create}"
                        Command="{Binding CreateCommand}"
                        IsEnabled="{Binding CanCreate}"
                        IsDefault="True"/>
            </StackPanel>
        </Grid>
    </DockPanel>
</mah:MetroWindow>
