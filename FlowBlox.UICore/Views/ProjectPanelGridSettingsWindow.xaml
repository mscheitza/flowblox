<mah:MetroWindow
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    x:Class="FlowBlox.UICore.Views.ProjectPanelGridSettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:resources="clr-namespace:FlowBlox.UICore.Resources"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    mc:Ignorable="d"
    Title="{x:Static resources:ProjectPanelGridSettingsWindow.Title}"
    Width="700"
    Height="500"
    WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/FlowBlox.UICore;component/Views/MahAppMetroResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel Margin="10">
        <Border Background="#FFEEEEEE" DockPanel.Dock="Top" Height="50" Padding="8">
            <StackPanel Orientation="Horizontal">
                <iconPacks:PackIconMaterial Kind="CogBox"
                                            Width="28"
                                            Height="28"
                                            Margin="0,0,10,0"
                                            VerticalAlignment="Center"
                                            Foreground="DarkSlateGray" />
                <TextBlock Text="{x:Static resources:ProjectPanelGridSettingsWindow.Header_Title}"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           FontSize="16" />
            </StackPanel>
        </Border>

        <Border Background="#EDF3F9"
                DockPanel.Dock="Top"
                Padding="12"
                CornerRadius="4"
                Margin="0,8,0,8">
            <TextBlock Text="{x:Static resources:ProjectPanelGridSettingsWindow.Header_Description}"
                       Foreground="DarkSlateGray"
                       TextWrapping="Wrap" />
        </Border>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        Orientation="Vertical">
                <TextBlock Text="{x:Static resources:ProjectPanelGridSettingsWindow.Label_GridWidth}"
                           Margin="0,0,0,6" />
                <TextBox x:Name="GridWidthTextBox"
                         Height="32"
                         Text="{Binding GridWidth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         VerticalContentAlignment="Center"
                         PreviewTextInput="NumericTextBox_PreviewTextInput" />

                <TextBlock Text="{x:Static resources:ProjectPanelGridSettingsWindow.Label_GridHeight}"
                           Margin="0,16,0,6" />
                <TextBox x:Name="GridHeightTextBox"
                         Height="32"
                         Text="{Binding GridHeight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         VerticalContentAlignment="Center"
                         PreviewTextInput="NumericTextBox_PreviewTextInput" />

                <TextBlock Text="{x:Static resources:ProjectPanelGridSettingsWindow.Label_ResetNotifications}"
                           Margin="0,16,0,6" />
                <mah:ToggleSwitch IsOn="{Binding ResetNotificationsOnRuntimeFinish, Mode=TwoWay}"
                                  HorizontalAlignment="Left"
                                  OffContent="{x:Static resources:ProjectPanelGridSettingsWindow.Toggle_Off}"
                                  OnContent="{x:Static resources:ProjectPanelGridSettingsWindow.Toggle_On}">
                    <mah:ToggleSwitch.ToolTip>
                        <TextBlock Text="{x:Static resources:ProjectPanelGridSettingsWindow.Tooltip_ResetNotifications}"
                                   TextWrapping="Wrap"
                                   MaxWidth="480" />
                    </mah:ToggleSwitch.ToolTip>
                </mah:ToggleSwitch>
            </StackPanel>

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,10,0,0">
                <Button Margin="0,0,6,0"
                        IsCancel="True"
                        Click="BackButton_Click">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="ArrowLeft"
                                                        Width="14"
                                                        Height="14"
                                                        Margin="0,0,6,0"
                                                        Foreground="#555" />
                            <TextBlock Text="{x:Static resources:ProjectPanelGridSettingsWindow.Button_Back}" />
                        </StackPanel>
                    </Button.Content>
                </Button>

                <Button IsDefault="True"
                        Click="ApplyButton_Click">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Check"
                                                        Width="14"
                                                        Height="14"
                                                        Margin="0,0,6,0"
                                                        Foreground="#2E7D32" />
                            <TextBlock Text="{x:Static resources:ProjectPanelGridSettingsWindow.Button_Apply}" />
                        </StackPanel>
                    </Button.Content>
                </Button>
            </StackPanel>
        </Grid>
    </DockPanel>
</mah:MetroWindow>
