<mah:MetroWindow
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    x:Class="FlowBlox.UICore.Views.PasswordResetWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:FlowBlox.UICore.Converters"
    xmlns:resources="clr-namespace:FlowBlox.UICore.Resources"
    xmlns:viewModel="clr-namespace:FlowBlox.UICore.ViewModels"
    Title="{x:Static resources:PasswordResetWindow.Window_Title}"
    SizeToContent="WidthAndHeight"
    MinWidth="600"
    MinHeight="350"
    WindowStartupLocation="CenterOwner">

    <Window.DataContext>
        <viewModel:PasswordResetViewModel />
    </Window.DataContext>
    
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/FlowBlox.UICore;component/Views/MahAppMetroResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- E-Mail oder Benutzername -->
        <StackPanel Grid.Row="0" Margin="10">
            <Label Content="{x:Static resources:PasswordResetWindow.Label_EmailOrUsername}" HorizontalAlignment="Left" />
            <TextBox Text="{Binding EmailOrUsername, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>

        <!-- Captcha -->
        <StackPanel Grid.Row="1" Margin="10">
            <Label Content="{x:Static resources:PasswordResetWindow.Label_Captcha}" HorizontalAlignment="Left" />
            <Image Source="{Binding CaptchaResponse.CaptchaImage}" Height="40" Width="140" Stretch="None" HorizontalAlignment="Left" />
            <Label Content="{x:Static resources:PasswordResetWindow.Label_CaptchaInstruction}" HorizontalAlignment="Left" />
            <TextBox Text="{Binding CaptchaCode, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>

        <!-- Fehlertext -->
        <TextBlock Grid.Row="2"
                   Text="{Binding ErrorText}"
                   Foreground="Red"
                   Margin="0,5,0,0"
                   TextWrapping="Wrap" />

        <!-- Passwort zurücksetzen Button -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button 
                Content="{x:Static resources:PasswordResetWindow.Button_Close}" 
                Command="{Binding CloseCommand}" 
                Margin="5,5,0,5" />

            <Button Content="{x:Static resources:PasswordResetWindow.Button_ResetPassword}"
                    Command="{Binding GenerateResetCodeCommand}"
                    IsEnabled="{Binding CanGenerateResetCode}"
                    HorizontalAlignment="Right"
                    Margin="5,5,0,5" />
        </StackPanel>

        <!-- Weitere Felder (Code, Passwort, Passwort-Wiederholung) -->
        <StackPanel Grid.Row="4" Margin="10" Visibility="{Binding IsResetCodeSent, Converter={StaticResource BoolToVisibilityConverter}}">
            <Label Content="{x:Static resources:PasswordResetWindow.Label_ResetCode}" HorizontalAlignment="Left" />
            <TextBox Text="{Binding ResetCode, UpdateSourceTrigger=PropertyChanged}" />

            <Label Content="{x:Static resources:PasswordResetWindow.Label_NewPassword}" HorizontalAlignment="Left" />
            <PasswordBox x:Name="NewPasswordBox" PasswordChanged="NewPasswordBox_PasswordChanged" />

            <Label Content="{x:Static resources:PasswordResetWindow.Label_NewPasswordRepeat}" HorizontalAlignment="Left" />
            <PasswordBox x:Name="NewPasswordRepeatBox" PasswordChanged="NewPasswordRepeatBox_PasswordChanged" />

            <Button Content="{x:Static resources:PasswordResetWindow.Button_ConfirmPasswordChange}"
                    Command="{Binding ChangePasswordCommand}"
                    IsEnabled="{Binding CanChangePassword}"
                    Margin="0,5,0,5"
                    HorizontalAlignment="Right"/>
        </StackPanel>
    </Grid>
</mah:MetroWindow>
