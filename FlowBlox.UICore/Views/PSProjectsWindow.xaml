<mah:MetroWindow
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    x:Class="FlowBlox.UICore.Views.PSProjectsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModel="clr-namespace:FlowBlox.UICore.ViewModels"
    xmlns:converters="clr-namespace:FlowBlox.UICore.Converters"
    xmlns:resources="clr-namespace:FlowBlox.UICore.Resources"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    Title="{x:Static resources:PSProjectsWindow.Title}"
    Height="800"
    Width="1100"
    mc:Ignorable="d"
    WindowStartupLocation="CenterOwner">

    <Window.DataContext>
        <viewModel:PSProjectsViewModel />
    </Window.DataContext>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/FlowBlox.UICore;component/Views/MahAppMetroResources.xaml" />
                <ResourceDictionary Source="/FlowBlox.UICore;component/Views/Styles/FlowBloxCustomStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
            <converters:CountToVisibilityConverter x:Key="CountToVisibilityConverter"/>
            <converters:EnumDisplayNameConverter x:Key="EnumDisplayNameConverter"/>
            <converters:CollectionContainsToVisibilityConverter x:Key="CollectionContainsToVisibilityConverter"/>

            <converters:ListViewWidthToColumnWidthConverter x:Key="ListViewWidthToColumnWidthConverter"
                                                            PaddingAndScrollbarCompensation="40"/>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel Margin="10">

        <!-- Header -->
        <Border Background="#FFEEEEEE"
                DockPanel.Dock="Top"
                Height="50"
                Padding="8">
            <StackPanel Orientation="Horizontal">
                <iconPacks:PackIconMaterial Kind="FolderSearchOutline"
                                            Width="30"
                                            Height="30"
                                            Margin="0,0,10,0"
                                            VerticalAlignment="Center"
                                            Foreground="DarkSlateGray"/>
                <TextBlock Text="{x:Static resources:PSProjectsWindow.Header_Title_Main}"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           FontSize="16"/>
            </StackPanel>
        </Border>

        <!-- Description -->
        <Border Background="#EDF3F9"
                DockPanel.Dock="Top"
                Padding="12"
                CornerRadius="4"
                Margin="0,8,0,10">
            <TextBlock Text="{x:Static resources:PSProjectsWindow.Header_Description_Main}"
                       FontWeight="UltraLight"
                       Foreground="DarkSlateGray"
                       TextWrapping="Wrap"/>
        </Border>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <ToolBar Grid.Row="0" VerticalAlignment="Center">

                <Button Command="{Binding LoginCommand}"
                        Visibility="{Binding CanLogin, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Account" Margin="0,0,5,0"/>
                            <TextBlock Text="{x:Static resources:PSProjectsWindow.Button_Login}"/>
                        </StackPanel>
                    </Button.Content>
                </Button>

                <Button Command="{Binding RegisterCommand}"
                        Visibility="{Binding CanRegister, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="AccountPlus" Margin="0,0,5,0"/>
                            <TextBlock Text="{x:Static resources:ExtensionsWindow.Button_Register}"/>
                        </StackPanel>
                    </Button.Content>
                </Button>

                <Button Command="{Binding LogoutCommand}"
                        Visibility="{Binding CanLogout, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Logout" Margin="0,0,5,0"/>
                            <TextBlock Text="{x:Static resources:PSProjectsWindow.Button_Logout}"/>
                        </StackPanel>
                    </Button.Content>
                </Button>

                <Separator Visibility="{Binding CanToggleMyProjects, Converter={StaticResource BoolToVisibilityConverter}}" />

                <!-- Filter: My/Public -->
                <ToggleButton IsChecked="{Binding IsMine}"
                              Visibility="{Binding CanToggleMyProjects, Converter={StaticResource BoolToVisibilityConverter}}"
                              ToolTip="{x:Static resources:PSProjectsWindow.Tooltip_FilterMine}">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="AccountBoxOutline" Margin="0,0,5,0"/>
                        <TextBlock Text="{x:Static resources:PSProjectsWindow.Toggle_MyProjects}"/>
                    </StackPanel>
                </ToggleButton>

                <Separator/>

                <!-- User display -->
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Visibility="{Binding ActiveUser, Converter={StaticResource NullToVisibilityConverter}}">

                    <iconPacks:PackIconMaterial Kind="Account"
                                                Width="12"
                                                Height="12"
                                                VerticalAlignment="Center"
                                                Foreground="Dimgray"
                                                Margin="0,0,3,0" />

                    <Label FontWeight="SemiBold"
                           Content="{Binding ActiveUser.UserName}"
                           VerticalAlignment="Center"
                           Margin="0,0,4,0" />

                    <!-- Edit user properties -->
                    <Button Command="{Binding EditUserPropertiesCommand}"
                            Padding="2"
                            Margin="0,0,0,0"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0">
                        <iconPacks:PackIconMaterial Kind="PencilOutline"
                                                    Width="14"
                                                    Height="14"
                                                    Foreground="DimGray"
                                                    VerticalAlignment="Center" />
                    </Button>
                </StackPanel>

            </ToolBar>

            <!-- Main -->
            <Grid Grid.Row="1" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Search -->
                <StackPanel Grid.Column="0" Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBox Width="260"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             KeyDown="SearchTextBox_KeyDown"/>
                    <Button Margin="6,0,0,0" Command="{Binding SearchCommand}">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="Magnify" Margin="0,0,5,0"/>
                                <TextBlock Text="{x:Static resources:PSProjectsWindow.Button_Search}"/>
                            </StackPanel>
                        </Button.Content>
                    </Button>
                </StackPanel>

                <!-- List + Empty state -->
                <Grid Grid.Column="0" Grid.Row="1">
                    <ListView x:Name="ProjectsListView"
                              ItemsSource="{Binding SearchResults}"
                              SelectedItem="{Binding SelectedProject}"
                              MouseDoubleClick="ProjectsListView_MouseDoubleClick">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="{x:Static resources:PSProjectsWindow.Header_Name}"
                                                DisplayMemberBinding="{Binding Name}"
                                                Width="{Binding ElementName=ProjectsListView,
                                                                Path=ActualWidth,
                                                                Converter={StaticResource ListViewWidthToColumnWidthConverter},
                                                                ConverterParameter=0.25}"/>

                                <GridViewColumn Header="{x:Static resources:PSProjectsWindow.Header_Description}"
                                                DisplayMemberBinding="{Binding Description}"
                                                Width="{Binding ElementName=ProjectsListView,
                                                                Path=ActualWidth,
                                                                Converter={StaticResource ListViewWidthToColumnWidthConverter},
                                                                ConverterParameter=0.55}"/>

                                <GridViewColumn Header="{x:Static resources:PSProjectsWindow.Header_UpdatedAt}"
                                                Width="{Binding ElementName=ProjectsListView,
                                                                Path=ActualWidth,
                                                                Converter={StaticResource ListViewWidthToColumnWidthConverter},
                                                                ConverterParameter=0.20}">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding UpdatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <!-- No results -->
                    <Grid Margin="20"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Center"
                          Visibility="{Binding SearchResults.Count, Converter={StaticResource CountToVisibilityConverter}, ConverterParameter=Reverse}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <iconPacks:PackIconMaterial Kind="AlertCircleOutline"
                                                    Width="16"
                                                    Height="16"
                                                    Foreground="Gray"
                                                    VerticalAlignment="Center"/>

                        <TextBlock Grid.Column="1"
                                   Text="{x:Static resources:PSProjectsWindow.Text_NoSearchResults}"
                                   FontSize="14"
                                   Foreground="Gray"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"/>
                    </Grid>
                </Grid>

                <!-- Details -->
                <ScrollViewer Grid.Column="1"
                              Grid.RowSpan="2"
                              Margin="10,0,0,0"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">

                    <TabControl BorderThickness="0"
                                Background="Transparent"
                                Visibility="{Binding IsProjectSelected, Converter={StaticResource BoolToVisibilityConverter}}">

                        <!-- Tab: Details -->
                        <TabItem Header="{x:Static resources:PSProjectsWindow.Tab_Details}">
                            <TabItem.HeaderTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                                        <iconPacks:PackIconMaterial Kind="InformationOutline"
                                                                    Width="16"
                                                                    Height="16"
                                                                    Margin="0,0,8,0"
                                                                    VerticalAlignment="Center"
                                                                    Foreground="#3A6EA5"/>
                                        <TextBlock Text="{Binding}"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Padding="0,5"/>
                                    </StackPanel>
                                </DataTemplate>
                            </TabItem.HeaderTemplate>

                            <StackPanel Margin="0,10,0,0">

                                <!-- Name -->
                                <Label Content="{x:Static resources:PSProjectsWindow.Label_ProjectName}"
                                       FontWeight="DemiBold"
                                       Margin="0,0,0,5"/>

                                <StackPanel Margin="5,0,0,8"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{Binding SelectedProject.Name}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>

                                    <Button Style="{StaticResource FlowBlox.CopyIconButton}"
                                            Command="{Binding CopyToClipboardCommand}"
                                            CommandParameter="{Binding SelectedProject.Name}"
                                            Margin="6,0,0,0"
                                            ToolTip="{x:Static resources:PSProjectsWindow.Tooltip_CopyToClipboard}">
                                        <iconPacks:PackIconMaterial Kind="ContentCopy"
                                                                    Width="16"
                                                                    Height="16"
                                                                    Style="{StaticResource FlowBlox.CopyIcon}"/>
                                    </Button>
                                </StackPanel>

                                <Label Content="{x:Static resources:PSProjectsWindow.Label_ProjectDescription}"
                                       FontWeight="DemiBold"
                                       Margin="0,5,0,5"/>
                                <TextBlock Text="{Binding SelectedProject.Description}"
                                           Margin="5,0,0,8"
                                           TextWrapping="Wrap"/>

                                <Label Content="{x:Static resources:PSProjectsWindow.Label_ProjectGuid}"
                                       FontWeight="DemiBold"
                                       Margin="0,5,0,5"/>

                                <!-- GUID -->
                                <StackPanel Margin="5,0,0,8"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{Binding SelectedProject.Guid}"
                                               VerticalAlignment="Center"
                                               TextWrapping="Wrap"/>

                                    <Button Style="{StaticResource FlowBlox.CopyIconButton}"
                                            Command="{Binding CopyToClipboardCommand}"
                                            CommandParameter="{Binding SelectedProject.Guid}"
                                            Margin="6,0,0,0"
                                            ToolTip="{x:Static resources:PSProjectsWindow.Tooltip_CopyToClipboard}">
                                        <iconPacks:PackIconMaterial Kind="ContentCopy"
                                                                    Width="16"
                                                                    Height="16"
                                                                    Style="{StaticResource FlowBlox.CopyIcon}"/>
                                    </Button>
                                </StackPanel>

                                <Label Content="{x:Static resources:PSProjectsWindow.Label_CreatedAt}"
                                       FontWeight="DemiBold"
                                       Margin="0,5,0,5"/>
                                <TextBlock Text="{Binding SelectedProject.CreatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}"
                                           Margin="5,0,0,8"/>

                                <Label Content="{x:Static resources:PSProjectsWindow.Label_UpdatedAt}"
                                       FontWeight="DemiBold"
                                       Margin="0,5,0,5"/>
                                <TextBlock Text="{Binding SelectedProject.UpdatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}"
                                           Margin="5,0,0,8"/>

                                <Label Content="{x:Static resources:PSProjectsWindow.Label_Visibility}"
                                       FontWeight="DemiBold"
                                       Margin="0,5,0,5"/>
                                <TextBlock Text="{Binding SelectedProject.Visibility, Converter={StaticResource EnumDisplayNameConverter}}"
                                           Margin="5,0,0,8"/>
                            </StackPanel>
                        </TabItem>

                        <!-- Tab: Versions -->
                        <TabItem Header="{x:Static resources:PSProjectsWindow.Tab_ProjectVersions}">
                            <TabItem.HeaderTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                                        <iconPacks:PackIconMaterial Kind="SourceBranch"
                                                                    Width="16"
                                                                    Height="16"
                                                                    Margin="0,0,8,0"
                                                                    VerticalAlignment="Center"
                                                                    Foreground="#3A6EA5"/>
                                        <TextBlock Text="{Binding}"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Padding="0,5"/>
                                    </StackPanel>
                                </DataTemplate>
                            </TabItem.HeaderTemplate>

                            <Grid Margin="0,10,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Versions toolbar (icon-only + tooltips) -->
                                <ToolBar Grid.Row="0" Margin="0,0,0,8">

                                    <Button Command="{Binding CreateVersionCommand}"
                                            IsEnabled="{Binding CanManageVersions}"
                                            ToolTip="{x:Static resources:PSProjectsWindow.Tooltip_CreateStableVersion}">
                                        <iconPacks:PackIconMaterial Kind="SourceBranchPlus" Width="16" Height="16"/>
                                    </Button>

                                    <Button Command="{Binding EditVersionCommand}"
                                            IsEnabled="{Binding CanEditSelectedVersion}"
                                            Margin="6,0,0,0"
                                            ToolTip="{x:Static resources:PSProjectsWindow.Tooltip_EditVersionMetadata}">
                                        <iconPacks:PackIconMaterial Kind="PencilOutline" Width="16" Height="16"/>
                                    </Button>

                                    <Button Command="{Binding DownloadVersionCommand}"
                                            IsEnabled="{Binding CanDownloadSelectedVersion}"
                                            Margin="6,0,0,0"
                                            ToolTip="{x:Static resources:PSProjectsWindow.Tooltip_DownloadVersion}">
                                        <iconPacks:PackIconMaterial Kind="DownloadOutline" Width="16" Height="16"/>
                                    </Button>

                                    <Button Command="{Binding RefreshVersionsCommand}"
                                            IsEnabled="{Binding CanManageVersions}"
                                            Margin="10,0,0,0"
                                            ToolTip="{x:Static resources:PSProjectsWindow.Tooltip_RefreshVersions}">
                                        <iconPacks:PackIconMaterial Kind="Refresh" Width="16" Height="16"/>
                                    </Button>

                                </ToolBar>

                                <!-- Versions list -->
                                <ListView Grid.Row="1"
                                          ItemsSource="{Binding ProjectVersions}"
                                          SelectedItem="{Binding SelectedVersion}">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="{x:Static resources:PSProjectsWindow.Header_Version}"
                                                            DisplayMemberBinding="{Binding VersionNumber}"
                                                            Width="70"/>
                                            <GridViewColumn Header="{x:Static resources:PSProjectsWindow.Header_CreatedAt}"
                                                            Width="150">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding CreatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <GridViewColumn Header="{x:Static resources:PSProjectsWindow.Header_Comment}"
                                                            DisplayMemberBinding="{Binding Comment}"
                                                            Width="260"/>
                                        </GridView>
                                    </ListView.View>
                                </ListView>

                                <!-- Version details below the table -->
                                <Border Grid.Row="2"
                                        Margin="0,10,0,0"
                                        Padding="12"
                                        CornerRadius="4"
                                        Background="#FFFAF3D1"
                                        BorderBrush="#FFE0C869"
                                        BorderThickness="1"
                                        Visibility="{Binding IsVersionSelected, Converter={StaticResource BoolToVisibilityConverter}}">

                                    <StackPanel>

                                        <!-- Heading -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <iconPacks:PackIconMaterial Kind="InformationOutline"
                                                                        Width="16"
                                                                        Height="16"
                                                                        Margin="0,1,8,0"
                                                                        Foreground="#FF6B5A1E"
                                                                        VerticalAlignment="Top"/>
                                            <TextBlock Text="{x:Static resources:PSProjectsWindow.Label_VersionDetailsHeader}"
                                                       FontWeight="DemiBold"
                                                       Foreground="#FF6B5A1E"
                                                       FontSize="14"/>
                                        </StackPanel>

                                        <Label Content="{x:Static resources:PSProjectsWindow.Label_VersionNumber}"
                                               FontWeight="DemiBold"
                                               Margin="0,0,0,5"/>
                                        <TextBlock Text="{Binding SelectedVersion.VersionNumber}" Margin="5,0,0,8"/>

                                        <Label Content="{x:Static resources:PSProjectsWindow.Label_VersionCreatedAt}"
                                               FontWeight="DemiBold"
                                               Margin="0,5,0,5"/>
                                        <TextBlock Text="{Binding SelectedVersion.CreatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}"
                                                   Margin="5,0,0,8"/>

                                        <Label Content="{x:Static resources:PSProjectsWindow.Label_VersionComment}"
                                               FontWeight="DemiBold"
                                               Margin="0,5,0,5"/>
                                        <TextBlock Text="{Binding SelectedVersion.Comment}"
                                                   Margin="5,0,0,0"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                            </Grid>
                        </TabItem>

                    </TabControl>

                </ScrollViewer>
            </Grid>

            <!-- Bottom buttons -->
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,10,0,0">

                <!-- Open latest -->
                <Button Margin="0,0,6,0"
                        Command="{Binding OpenProjectCommand}"
                        IsEnabled="{Binding IsProjectSelected}">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="FolderOpenOutline" Margin="0,0,5,0"/>
                            <TextBlock Text="{x:Static resources:PSProjectsWindow.Button_Open}"/>
                        </StackPanel>
                    </Button.Content>
                </Button>

                <!-- Open selected version (only visible when a version is selected) -->
                <Button Margin="0,0,6,0"
                        Command="{Binding OpenVersionCommand}"
                        Visibility="{Binding IsVersionSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="SourceBranch" Margin="0,0,5,0"/>
                            <TextBlock Text="{x:Static resources:PSProjectsWindow.Button_OpenVersion}"/>
                        </StackPanel>
                    </Button.Content>
                </Button>

                <Button Margin="0,0,6,0"
                        Command="{Binding EditProjectCommand}"
                        IsEnabled="{Binding CanEditProject}"
                        Visibility="{Binding IsMine, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="PencilOutline" Margin="0,0,5,0"/>
                            <TextBlock Text="{x:Static resources:PSProjectsWindow.Button_Edit}"/>
                        </StackPanel>
                    </Button.Content>
                </Button>

                <Button Command="{Binding CloseCommand}" IsCancel="True">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Close" Margin="0,0,5,0"/>
                            <TextBlock Text="{x:Static resources:PSProjectsWindow.Button_Close}"/>
                        </StackPanel>
                    </Button.Content>
                </Button>
            </StackPanel>

        </Grid>
    </DockPanel>
</mah:MetroWindow>