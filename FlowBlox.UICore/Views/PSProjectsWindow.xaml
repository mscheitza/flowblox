<mah:MetroWindow
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    x:Class="FlowBlox.UICore.Views.PSProjectsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModel="clr-namespace:FlowBlox.UICore.ViewModels"
    xmlns:converters="clr-namespace:FlowBlox.UICore.Converters"
    xmlns:resources="clr-namespace:FlowBlox.UICore.Resources"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    Title="{x:Static resources:PSProjectsWindow.Title}"
    Height="520" Width="950"
    mc:Ignorable="d"
    WindowStartupLocation="CenterOwner">

    <Window.DataContext>
        <viewModel:PSProjectsViewModel />
    </Window.DataContext>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/FlowBlox.UICore;component/Views/MahAppMetroResources.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
            <converters:CountToVisibilityConverter x:Key="CountToVisibilityConverter" />
            <converters:EnumDisplayNameConverter x:Key="EnumDisplayNameConverter" />
            <converters:CollectionContainsToVisibilityConverter x:Key="CollectionContainsToVisibilityConverter"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <ToolBar Grid.Row="0" VerticalAlignment="Center">

            <Button Command="{Binding LoginCommand}"
                Visibility="{Binding CanLogin, Converter={StaticResource BoolToVisibilityConverter}}">
                <Button.Content>
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Account"
                                        Margin="0,0,5,0"/>
                        <TextBlock Text="{x:Static resources:PSProjectsWindow.Button_Login}"/>
                    </StackPanel>
                </Button.Content>
            </Button>

            <Button Command="{Binding RegisterCommand}"
                Visibility="{Binding CanRegister, Converter={StaticResource BoolToVisibilityConverter}}">
                <Button.Content>
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="AccountPlus"
                                        Margin="0,0,5,0"/>
                        <TextBlock Text="{x:Static resources:ExtensionsWindow.Button_Register}"/>
                    </StackPanel>
                </Button.Content>
            </Button>

            <Button Command="{Binding LogoutCommand}"
                Visibility="{Binding CanLogout, Converter={StaticResource BoolToVisibilityConverter}}">
                <Button.Content>
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Logout"
                                        Margin="0,0,5,0"/>
                        <TextBlock Text="{x:Static resources:PSProjectsWindow.Button_Logout}"/>
                    </StackPanel>
                </Button.Content>
            </Button>

            <Separator/>

            <!-- Filter: My/Public -->
            <ToggleButton IsChecked="{Binding IsMine}"
                          ToolTip="{x:Static resources:PSProjectsWindow.Tooltip_FilterMine}">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="AccountBoxOutline" Margin="0,0,5,0"/>
                    <TextBlock Text="{x:Static resources:PSProjectsWindow.Toggle_MyProjects}"/>
                </StackPanel>
            </ToggleButton>

            <Separator/>

            <!-- User display -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                        Visibility="{Binding ActiveUser, Converter={StaticResource NullToVisibilityConverter}}">
                <iconPacks:PackIconMaterial Kind="Account" Width="12" Height="12" VerticalAlignment="Center" Foreground="Dimgray" Margin="0,0,3,0" />
                <Label FontWeight="SemiBold" Content="{Binding ActiveUser.UserName}" VerticalAlignment="Center" />
            </StackPanel>
        </ToolBar>

        <!-- Main content -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Search -->
            <StackPanel Grid.Column="0" Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                <TextBox Width="260"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         KeyDown="SearchTextBox_KeyDown"/>
                <Button Margin="6,0,0,0" Command="{Binding SearchCommand}">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Magnify" Margin="0,0,5,0"/>
                            <TextBlock Text="{x:Static resources:PSProjectsWindow.Button_Search}"/>
                        </StackPanel>
                    </Button.Content>
                </Button>
            </StackPanel>

            <!-- List -->
            <Grid Grid.Column="0" Grid.Row="1">
                <ListView ItemsSource="{Binding SearchResults}"
                          SelectedItem="{Binding SelectedProject}"
                          MouseDoubleClick="ProjectsListView_MouseDoubleClick">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="{x:Static resources:PSProjectsWindow.Header_Name}" DisplayMemberBinding="{Binding Name}" Width="220"/>
                            <GridViewColumn Header="{x:Static resources:PSProjectsWindow.Header_Description}" DisplayMemberBinding="{Binding Description}" Width="380"/>
                            <GridViewColumn Header="{x:Static resources:PSProjectsWindow.Header_UpdatedAt}" Width="160">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding UpdatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>

                <!-- No results -->
                <Grid Margin="20"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Center"
                      Visibility="{Binding SearchResults.Count, Converter={StaticResource CountToVisibilityConverter}, ConverterParameter=Reverse}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <iconPacks:PackIconMaterial Kind="AlertCircleOutline"
                                                Width="16"
                                                Height="16"
                                                Foreground="Gray"
                                                VerticalAlignment="Center"/>

                    <TextBlock Grid.Column="1"
                               Text="{x:Static resources:PSProjectsWindow.Text_NoSearchResults}"
                               FontSize="14"
                               Foreground="Gray"
                               Margin="10,0,0,0"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"/>
                </Grid>
            </Grid>

            <!-- Details -->
            <ScrollViewer Grid.Column="1" Grid.RowSpan="2" Margin="10,0,0,0"
                          VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Visibility="{Binding IsProjectSelected, Converter={StaticResource BoolToVisibilityConverter}}">

                    <Label Content="{x:Static resources:PSProjectsWindow.Label_ProjectName}" FontWeight="DemiBold" Margin="0,0,0,5" />
                    <TextBlock Text="{Binding SelectedProject.Name}" Margin="5,0,0,8" />

                    <Label Content="{x:Static resources:PSProjectsWindow.Label_ProjectDescription}" FontWeight="DemiBold" Margin="0,5,0,5" />
                    <TextBlock Text="{Binding SelectedProject.Description}" Margin="5,0,0,8" TextWrapping="Wrap" />

                    <Label Content="{x:Static resources:PSProjectsWindow.Label_ProjectGuid}" FontWeight="DemiBold" Margin="0,5,0,5" />
                    <TextBlock Text="{Binding SelectedProject.Guid}" Margin="5,0,0,8" TextWrapping="Wrap"/>

                    <Label Content="{x:Static resources:PSProjectsWindow.Label_CreatedAt}" FontWeight="DemiBold" Margin="0,5,0,5" />
                    <TextBlock Text="{Binding SelectedProject.CreatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" Margin="5,0,0,8" />

                    <Label Content="{x:Static resources:PSProjectsWindow.Label_UpdatedAt}" FontWeight="DemiBold" Margin="0,5,0,5" />
                    <TextBlock Text="{Binding SelectedProject.UpdatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" Margin="5,0,0,8" />

                    <Label Content="{x:Static resources:PSProjectsWindow.Label_Visibility}" FontWeight="DemiBold" Margin="0,5,0,5" />
                    <TextBlock Text="{Binding SelectedProject.Visibility, Converter={StaticResource EnumDisplayNameConverter}}" Margin="5,0,0,8" />

                </StackPanel>
            </ScrollViewer>

        </Grid>

        <!-- Bottom buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button Margin="0,0,6,0" Command="{Binding OpenProjectCommand}" IsEnabled="{Binding IsProjectSelected}">
                <Button.Content>
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="FolderOpenOutline" Margin="0,0,5,0"/>
                        <TextBlock Text="{x:Static resources:PSProjectsWindow.Button_Open}"/>
                    </StackPanel>
                </Button.Content>
            </Button>
            <Button Margin="0,0,6,0"
                Command="{Binding EditProjectCommand}"
                IsEnabled="{Binding CanEditProject}"
                Visibility="{Binding IsMine, Converter={StaticResource BoolToVisibilityConverter}}">
                <Button.Content>
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="PencilOutline" Margin="0,0,5,0"/>
                        <TextBlock Text="{x:Static resources:PSProjectsWindow.Button_Edit}"/>
                    </StackPanel>
                </Button.Content>
            </Button>

            <Button Command="{Binding CloseCommand}">
                <Button.Content>
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Close" Margin="0,0,5,0"/>
                        <TextBlock Text="{x:Static resources:PSProjectsWindow.Button_Close}"/>
                    </StackPanel>
                </Button.Content>
            </Button>
        </StackPanel>
    </Grid>
</mah:MetroWindow>
