<mah:MetroWindow  
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    x:Class="FlowBlox.UICore.Views.TestDefinitionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModel="clr-namespace:FlowBlox.UICore.ViewModels"
    xmlns:converters="clr-namespace:FlowBlox.UICore.Converters.TestDefinition"
    xmlns:globalConverters="clr-namespace:FlowBlox.UICore.Converters"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:resources="clr-namespace:FlowBlox.UICore.Resources"
    xmlns:coreEnums="clr-namespace:FlowBlox.Core.Enums;assembly=FlowBlox.Core"
    Title="{x:Static resources:TestDefinitionView.Title}"
    Height="800" Width="1200"
    mc:Ignorable="d">

    <Window.DataContext>
        <viewModel:TestDefinitionViewModel />
    </Window.DataContext>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/FlowBlox.UICore;component/Views/MahAppMetroResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <converters:ExecuteEnabledMultiConverter x:Key="ExecuteEnabledMultiConverter"/>
            <globalConverters:EnumDisplayNameConverter x:Key="EnumDisplayNameConverter"/>
            <converters:ExpectationConditionConverter x:Key="ExpectationConditionConverter"/>
            <converters:LogLevelToIconConverter x:Key="LogLevelToIconConverter"/>
            <converters:RuntimeLogsToVisibilityConverter x:Key="RuntimeLogsToVisibilityConverter"/>
            <converters:TestResultsToVisibilityConverter x:Key="TestResultsToVisibilityConverter"/>
            <converters:UserInputEnabledConverter x:Key="UserInputEnabledConverter"/>
            <converters:FlowBlockToVisibilityConverter x:Key="FlowBlockToVisibilityConverter"/>
            <converters:TabControlVisibilityConverter x:Key="TabControlVisibilityConverter"/>
            <globalConverters:CollectionContainsToVisibilityConverter x:Key="CollectionContainsToVisibilityConverter"/>
            <viewModel:TestDefinitionViewModel x:Key="TestDefinitionViewModel"/>
            <converters:IndexDisplayConverter x:Key="IndexDisplayConverter"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="10">
            <Label Content="{x:Static resources:TestDefinitionView.Label_Name}" />
            <TextBox Text="{Binding TestDefinition.Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,5"/>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <CheckBox IsChecked="{Binding TestDefinition.RequiredForExecution}" Margin="0,0,5,0" VerticalAlignment="Center"/>
                <Label Content="{x:Static resources:TestDefinitionView.Label_RequiredForExecution}" VerticalAlignment="Center" />
            </StackPanel>
        </StackPanel>

        <ScrollViewer Grid.Row="1" Margin="10">
            <StackPanel>
                <Grid Grid.IsSharedSizeScope="True">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="250" SharedSizeGroup="col1"/>
                            <ColumnDefinition Width="100" SharedSizeGroup="col2"/>
                            <ColumnDefinition Width="150" SharedSizeGroup="col3"/>
                            <ColumnDefinition Width="200" SharedSizeGroup="col4"/>
                            <ColumnDefinition Width="200" SharedSizeGroup="col5"/>
                            <ColumnDefinition Width="250" SharedSizeGroup="col6"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{x:Static resources:TestDefinitionView.Text_FlowBlock}" FontWeight="Bold" Grid.Column="0" Margin="0,0,5,0"/>
                        <GridSplitter Grid.Column="0" Width="2" Margin="1 0 1 0" HorizontalAlignment="Right" VerticalAlignment="Stretch" Background="LightGray" ShowsPreview="True"/>
                        <TextBlock Text="{x:Static resources:TestDefinitionView.Text_Execute}" FontWeight="Bold" Grid.Column="1" Margin="0,0,5,0"/>
                        <GridSplitter Grid.Column="1" Width="2" Margin="1 0 1 0" HorizontalAlignment="Right" VerticalAlignment="Stretch" Background="LightGray" ShowsPreview="True"/>
                        <TextBlock Text="{x:Static resources:TestDefinitionView.Text_FieldLabel}" FontWeight="Bold" Grid.Column="2" Margin="0,0,5,0"/>
                        <GridSplitter Grid.Column="2" Width="2" Margin="1 0 1 0" HorizontalAlignment="Right" VerticalAlignment="Stretch" Background="LightGray" ShowsPreview="True"/>
                        <TextBlock Text="{x:Static resources:TestDefinitionView.Text_SelectionMode}" FontWeight="Bold" Grid.Column="3" Margin="0,0,5,0"/>
                        <GridSplitter Grid.Column="3" Width="2" Margin="1 0 1 0" HorizontalAlignment="Right" VerticalAlignment="Stretch" Background="LightGray" ShowsPreview="True"/>
                        <TextBlock Text="{x:Static resources:TestDefinitionView.Text_UserInputFieldValue}" FontWeight="Bold" Grid.Column="4" Margin="0,0,5,0"/>
                        <GridSplitter Grid.Column="4" Width="2" Margin="1 0 1 0" HorizontalAlignment="Right" VerticalAlignment="Stretch" Background="LightGray" ShowsPreview="True"/>
                        <TextBlock Text="{x:Static resources:TestDefinitionView.Text_TestExpectations}" FontWeight="Bold" Grid.Column="5" Margin="0,0,5,0"/>
                    </Grid>

                    <ItemsControl Grid.Row="1" ItemsSource="{Binding TestDefinition.Entries}">
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Visibility">
                                    <Setter.Value>
                                        <MultiBinding Converter="{StaticResource CollectionContainsToVisibilityConverter}" ConverterParameter="Visible,Hidden">
                                            <Binding Path="DataContext.CapturedFlowBlocks" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                            <Binding Path="FlowBlock"/>
                                        </MultiBinding>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,10,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="250" SharedSizeGroup="col1"/>
                                        <ColumnDefinition Width="100" SharedSizeGroup="col2"/>
                                        <ColumnDefinition Width="150" SharedSizeGroup="col3"/>
                                        <ColumnDefinition Width="230" SharedSizeGroup="col4"/>
                                        <ColumnDefinition Width="200" SharedSizeGroup="col5"/>
                                        <ColumnDefinition Width="250" SharedSizeGroup="col6"/>
                                    </Grid.ColumnDefinitions>
                                    <Label Content="{Binding FlowBlock.Name}" Grid.Column="0" VerticalAlignment="Top"/>
                                    <CheckBox IsChecked="{Binding Execute}" Grid.Column="1" 
                                              VerticalAlignment="Top" 
                                              Visibility="{Binding FlowBlock, Converter={StaticResource FlowBlockToVisibilityConverter}}" 
                                              Margin="0 5 0 0">
                                        <CheckBox.IsEnabled>
                                            <MultiBinding Converter="{StaticResource ExecuteEnabledMultiConverter}">
                                                <Binding Path="DataContext.CurrentFlowBlock" RelativeSource="{RelativeSource AncestorType={x:Type Window}}" />
                                                <Binding />
                                                <Binding Path="DataContext.TestDefinitionUsages" RelativeSource="{RelativeSource AncestorType={x:Type Window}}" />
                                            </MultiBinding>
                                        </CheckBox.IsEnabled>
                                    </CheckBox>
                                    <ItemsControl ItemsSource="{Binding FlowBloxTestConfigurations}" Grid.Column="2" Grid.ColumnSpan="4">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0 0 0 5">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="150" SharedSizeGroup="col3"/>
                                                        <ColumnDefinition Width="230" SharedSizeGroup="col4"/>
                                                        <ColumnDefinition Width="200" SharedSizeGroup="col5"/>
                                                        <ColumnDefinition Width="250" SharedSizeGroup="col6"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding FieldElement.Name}" VerticalAlignment="Center"/>
                                                        <iconPacks:PackIconMaterial Kind="StarFourPointsOutline"
                                                            Width="16" 
                                                            Height="16" 
                                                            Margin="5,0,0,0"
                                                            Foreground="#E65100"
                                                            ToolTip="{x:Static resources:TestDefinitionView.Icon_RequiredForExecution_Tooltip}"
                                                            Visibility="{Binding RequiredForExecution, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="0,0,5,0">
                                                        <ComboBox SelectedItem="{Binding SelectionMode}"
                                                                  ItemsSource="{Binding PossibleSelectionModes}"
                                                                  VerticalAlignment="Center" Margin="0 0 0 5">
                                                            <ComboBox.ItemTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock Text="{Binding Converter={StaticResource EnumDisplayNameConverter}}"/>
                                                                </DataTemplate>
                                                            </ComboBox.ItemTemplate>
                                                        </ComboBox>

                                                        <TextBox Text="{Binding Index, UpdateSourceTrigger=PropertyChanged}"
                                                             VerticalAlignment="Center"
                                                             Margin="0,0,0,0"
                                                             mah:TextBoxHelper.Watermark="{x:Static resources:TestDefinitionView.Text_SelectionMode_Index_Watermark}"
                                                             Visibility="{Binding IsIndexVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                    </StackPanel>
                                                    
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top" IsEnabled="{Binding SelectionMode, Converter={StaticResource UserInputEnabledConverter}}">
                                                        <TextBox Text="{Binding UserInput, UpdateSourceTrigger=PropertyChanged}" 
                                                                 VerticalAlignment="Center" 
                                                                 Margin="0 0 5 0"
                                                                  />
                                                        <Button Margin="5,0,0,0"
                                                            Command="{Binding DataContext.EditContentCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                            CommandParameter="{Binding}">
                                                            <iconPacks:PackIconMaterial Kind="Pencil" Width="14" Height="14"/>
                                                        </Button>
                                                    </StackPanel>
                                                    
                                                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Top" 
                                                                Visibility="{Binding Path=DataContext.FlowBlock, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Grid, AncestorLevel=2}, Converter={StaticResource FlowBlockToVisibilityConverter}}">
                                                        <TextBox Text="{Binding ExpectationConditions, Converter={StaticResource ExpectationConditionConverter}}" VerticalAlignment="Center" IsReadOnly="True" Width="200" />
                                                        <Button Content="..." 
                                                                Margin="5,0,0,0"
                                                                Command="{Binding DataContext.EditConditionsCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" 
                                                                CommandParameter="{Binding}" />
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <!-- TabControl for Test Results and Runtime Logs -->
        <TabControl Grid.Row="2" Margin="10">

            <TabItem Header="{x:Static resources:TestDefinitionView.TabItem_Expectations}">
                <TabItem.HeaderTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontSize="16"/>
                    </DataTemplate>
                </TabItem.HeaderTemplate>

                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    
                    <!-- SelectedConfiguration -->
                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal" 
                                Margin="0,0,0,8" 
                                ToolTip="{x:Static resources:TestDefinitionView.StackPanel_SelectedConfiguration_Tooltip}">
                        <TextBlock VerticalAlignment="Center"
                           Text="{x:Static resources:TestDefinitionView.Label_SelectedConfiguration}"
                           Margin="0,0,8,0"/>
                        <ComboBox Width="380"
                          ItemsSource="{Binding Configurations}"
                          SelectedItem="{Binding SelectedConfiguration, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding FieldElement.Name}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <!-- Toolbar -->
                    <ToolBar Grid.Row="1">
                        <Button ToolTip="{x:Static resources:TestDefinitionView.Toolbar_Add}"
                                Command="{Binding AddExpectationCommand}">
                            <iconPacks:PackIconMaterial Kind="Plus" Width="16" Height="16" Foreground="DarkGreen" />
                        </Button>
                        <Button ToolTip="{x:Static resources:TestDefinitionView.Toolbar_Delete}"
                                Command="{Binding DeleteExpectationCommand}"
                                CommandParameter="{Binding SelectedExpectation}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsEnabled" Value="True">
                                            <Setter Property="Foreground" Value="#C62828"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
                                            <Setter Property="Opacity" Value="0.6"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <iconPacks:PackIconMaterial Kind="Delete" Width="16" Height="16" />
                        </Button>
                    </ToolBar>

                    <!-- ExpectationConditions -->
                    <DataGrid Grid.Row="2"
                      x:Name="expectationsGrid"
                      ItemsSource="{Binding SelectedConfiguration.ExpectationConditions}"
                      SelectedItem="{Binding SelectedExpectation, Mode=TwoWay}"
                      HorizontalAlignment="Stretch" 
                      VerticalAlignment="Stretch"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="True"
                      IsReadOnly="False">
                        
                        <!-- ExpectationTarget -->
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="{x:Static resources:TestDefinitionView.Column_ExpectationTarget}" Width="Auto" MinWidth="200">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock>
                                            <TextBlock.Text>
                                                <Binding Path="ExpectationConditionTarget" Converter="{StaticResource EnumDisplayNameConverter}"/>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox SelectedItem="{Binding ExpectationConditionTarget, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          ItemsSource="{Binding DataContext.ExpectationTargets, RelativeSource={RelativeSource AncestorType=Window}}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Converter={StaticResource EnumDisplayNameConverter}}"/>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <!-- Index -->
                            <DataGridTemplateColumn Header="{x:Static resources:TestDefinitionView.Column_Index}" Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock>
                                            <TextBlock.Text>
                                                <MultiBinding Converter="{StaticResource IndexDisplayConverter}">
                                                    <Binding Path="ExpectationConditionTarget"/>
                                                    <Binding Path="Index"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Index, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="80">
                                            <TextBox.Style>
                                                <Style TargetType="TextBox">
                                                    <Setter Property="IsEnabled" Value="False"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ExpectationConditionTarget}"
                                                                     Value="{x:Static coreEnums:ExpectationConditionTarget.ValueAtIndex}">
                                                            <Setter Property="IsEnabled" Value="True"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <!-- Operator -->
                            <DataGridTemplateColumn Header="{x:Static resources:TestDefinitionView.Column_Operator}" Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock>
                                            <TextBlock.Text>
                                                <Binding Path="Operator" Converter="{StaticResource EnumDisplayNameConverter}"/>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox SelectedItem="{Binding Operator, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                   ItemsSource="{Binding DataContext.ComparisonOperators, RelativeSource={RelativeSource AncestorType=Window}}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Converter={StaticResource EnumDisplayNameConverter}}"/>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <!-- Value -->
                            <DataGridTextColumn Header="{x:Static resources:TestDefinitionView.Column_Value}"
                                        Binding="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Width="2*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="{x:Static resources:TestDefinitionView.TabItem_TestResults}" Visibility="{Binding TestResults, Converter={StaticResource TestResultsToVisibilityConverter}}">
                <TabItem.HeaderTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontSize="16"/>
                    </DataTemplate>
                </TabItem.HeaderTemplate>
                <DataGrid x:Name="testResultsDataGrid" ItemsSource="{Binding TestResults}" AutoGenerateColumns="False">
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="{x:Static resources:TestDefinitionView.MenuItem_OpenInEditor}" 
                                      Command="{Binding OpenInEditorCommand, Source={StaticResource TestDefinitionViewModel}}" 
                                      CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}">
                                <MenuItem.Icon>
                                    <iconPacks:PackIconModern Kind="Edit" Width="14" Height="14" Margin="5,0,5,0"/>
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                </DataGrid>
            </TabItem>
            <TabItem Header="{x:Static resources:TestDefinitionView.TabItem_RuntimeLogs}" Visibility="{Binding RuntimeLogs, Converter={StaticResource RuntimeLogsToVisibilityConverter}}">
                <TabItem.HeaderTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontSize="16"/>
                    </DataTemplate>
                </TabItem.HeaderTemplate>
                <ListView ItemsSource="{Binding RuntimeLogs}">
                    <ListView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="{x:Static resources:TestDefinitionView.MenuItem_OpenInEditor}" 
                              Command="{Binding OpenInEditorCommand, Source={StaticResource TestDefinitionViewModel}}"
                              CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}">
                                <MenuItem.Icon>
                                    <iconPacks:PackIconModern Kind="Edit" Width="14" Height="14" Margin="0,0,5,0"/>
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </ListView.ContextMenu>
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="{x:Static resources:TestDefinitionView.GridViewColumn_Timestamp}" DisplayMemberBinding="{Binding Timestamp}"/>
                            <GridViewColumn Header="{x:Static resources:TestDefinitionView.GridViewColumn_LogLevel}">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <iconPacks:PackIconModern Kind="{Binding LogLevel, Converter={StaticResource LogLevelToIconConverter}}" Width="16" Height="16" Margin="0,0,5,0"/>
                                            <TextBlock Text="{Binding LogLevel}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="{x:Static resources:TestDefinitionView.GridViewColumn_Message}" DisplayMemberBinding="{Binding Message}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button IsCancel="True" Click="CancelButton_Click" Margin="5">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconModern Kind="ChevronLeft" Width="16" Height="16" Margin="0,0,5,0"/>
                    <TextBlock Text="{x:Static resources:TestDefinitionView.Button_Back}" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button IsDefault="True" Click="OkButton_Click" IsEnabled="{Binding CanApply}" Margin="5">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconModern Kind="Save" Width="16" Height="16" Margin="0,0,5,0"/>
                    <TextBlock Text="{x:Static resources:TestDefinitionView.Button_Save}" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Command="{Binding ExecuteTestCommand}" IsEnabled="{Binding CanExecute}" Margin="5">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconModern Kind="Cog" Width="16" Height="16" Margin="0,0,5,0"/>
                    <TextBlock Text="{x:Static resources:TestDefinitionView.Button_Execute}" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>

    </Grid>
</mah:MetroWindow>
