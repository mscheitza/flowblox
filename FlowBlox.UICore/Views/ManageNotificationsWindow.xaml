<mah:MetroWindow
    x:Class="FlowBlox.UICore.Views.ManageNotificationsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModel="clr-namespace:FlowBlox.UICore.ViewModels"
    xmlns:converters="clr-namespace:FlowBlox.UICore.Converters"
    xmlns:resources="clr-namespace:FlowBlox.UICore.Resources"
    Title="{x:Static resources:ManageNotificationsWindow.Title}"
    Height="400" Width="600" mc:Ignorable="d">

    <Window.DataContext>
        <viewModel:ManageNotificationOverridesViewModel />
    </Window.DataContext>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/FlowBlox.UICore;component/Views/MahAppMetroResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <converters:EnumDisplayNameConverter x:Key="EnumDisplayNameConverter" />
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel>

        <Border Background="#EDF3F9"
            DockPanel.Dock="Top"
            Padding="12"
            CornerRadius="4">
            <TextBlock Text="{x:Static resources:ManageNotificationsWindow.HeaderDescription}"
                   FontWeight="UltraLight"
                   Foreground="DarkSlateGray"
                   TextWrapping="Wrap"
                   TextTrimming="CharacterEllipsis" />
        </Border>

        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DataGrid Grid.Row="0"
                  ItemsSource="{Binding Items}"
                  AutoGenerateColumns="False"
                  HeadersVisibility="Column"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{x:Static resources:ManageNotificationsWindow.GridColumn_Message}" Binding="{Binding EnumDisplayName}" IsReadOnly="True" Width="*" />
                    <DataGridComboBoxColumn Header="{x:Static resources:ManageNotificationsWindow.GridColumn_NotificationType}"
                                        SelectedItemBinding="{Binding SelectedNotificationType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Width="*">

                        <DataGridComboBoxColumn.ElementStyle>
                            <Style TargetType="{x:Type ComboBox}">
                                <Setter Property="ItemsSource"
                                Value="{Binding DataContext.NotificationTypes, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" />
                                <Setter Property="ItemTemplate">
                                    <Setter.Value>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Converter={StaticResource EnumDisplayNameConverter}}" />
                                        </DataTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGridComboBoxColumn.ElementStyle>

                        <DataGridComboBoxColumn.EditingElementStyle>
                            <Style TargetType="{x:Type ComboBox}">
                                <Setter Property="ItemsSource"
                                Value="{Binding DataContext.NotificationTypes, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" />
                                <Setter Property="ItemTemplate">
                                    <Setter.Value>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Converter={StaticResource EnumDisplayNameConverter}}" />
                                        </DataTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGridComboBoxColumn.EditingElementStyle>

                    </DataGridComboBoxColumn>
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="{x:Static resources:ManageNotificationsWindow.Button_Back}" Width="100" Margin="0,0,10,0" Command="{Binding CancelCommand}" />
                <Button Content="{x:Static resources:ManageNotificationsWindow.Button_Apply}" Width="100" Command="{Binding OkCommand}" />
            </StackPanel>
        </Grid>
    </DockPanel>
</mah:MetroWindow>
