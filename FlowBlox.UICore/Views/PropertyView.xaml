<UserControl
    x:Class="FlowBlox.UICore.Views.PropertyView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModel="clr-namespace:FlowBlox.UICore.ViewModels.PropertyView"
    xmlns:resources="clr-namespace:FlowBlox.UICore.Resources"
    xmlns:converters="clr-namespace:FlowBlox.UICore.Converters"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:behavior="clr-namespace:FlowBlox.UICore.Behavior"
    mc:Ignorable="d">

    <UserControl.DataContext>
        <viewModel:PropertyViewModel />
    </UserControl.DataContext>
    
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <DockPanel>

        <!-- TabControl -->
        <TabControl ItemsSource="{Binding VisibleTabs}" Margin="4,0,4,0" DockPanel.Dock="Top">
            <TabControl.Resources>
                <Style TargetType="TabItem" BasedOn="{StaticResource {x:Type TabItem}}">
                    <Setter Property="Foreground" Value="DarkSlateGray"/>
                    <Setter Property="Background" Value="#FFEFF4F9"/>
                    <Setter Property="Padding" Value="10,4"/>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="FontWeight" Value="Normal"/>
                    <Setter Property="BorderBrush" Value="#FFEFF4F9"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#FFDAE6F2"/>
                            <Setter Property="Foreground" Value="Black"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#FFBBD6F0"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Foreground" Value="Black"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TabControl.Resources>

            <TabControl.Template>
                <ControlTemplate TargetType="{x:Type TabControl}">
                    <Grid KeyboardNavigation.TabNavigation="Local">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" 
                                      VerticalScrollBarVisibility="Disabled" 
                                      Grid.Row="0">
                            <ScrollViewer.Resources>
                                <Style TargetType="ScrollBar">
                                    <Setter Property="MinHeight" Value="10" />
                                    <Setter Property="Height" Value="5" />
                                    <Setter Property="MinHeight" Value="5" />
                                </Style>
                                <Style TargetType="RepeatButton" x:Key="ScrollBarButtonStyle">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </Style>
                            </ScrollViewer.Resources>
                            <TabPanel IsItemsHost="True" Margin="2,0,2,0" />
                        </ScrollViewer>
                        <ContentPresenter Grid.Row="1" ContentSource="SelectedContent" />
                    </Grid>
                </ControlTemplate>
            </TabControl.Template>
            <TabControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding TabTitle}"
                        FontSize="16"
                        Margin="0,0,0,6" />
                </DataTemplate>
            </TabControl.ItemTemplate>
            <TabControl.ContentTemplate>
                <DataTemplate>
                    <ScrollViewer>
                        <StackPanel>
                            <ItemsControl ItemsSource="{Binding Controls}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel behavior:ToolTipPreferenceBehavior.PreferChildToolTips="True"
                                                    Margin="0,0,0,10" 
                                                    IsEnabled="{Binding IsEnabled}" 
                                                    Visibility="{Binding IsActive, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <Border 
                                                Background="#D9E6F2" 
                                                Padding="4" 
                                                Margin="0,0,0,5" 
                                                CornerRadius="4"
                                                Visibility="{Binding UseLabel, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBlock 
                                                    Text="{Binding Label}" 
                                                    FontWeight="SemiBold"
                                                    Foreground="Black"
                                                    VerticalAlignment="Center" />
                                            </Border>
                                            <ContentControl Content="{Binding Control}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>
    </DockPanel>
</UserControl>