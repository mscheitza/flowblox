<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks">

    <!-- ====================== -->
    <!-- FlowBlox Custom Styles -->
    <!-- ====================== -->

    <Style x:Key="FlowBlox.CopyIconButton"
           TargetType="{x:Type Button}">

        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="MinWidth" Value="24"/>
        <Setter Property="MinHeight" Value="24"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="VerticalAlignment" Value="Center"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- Icon behavior when hosted inside FlowBlox.CopyIconButton -->
    <Style x:Key="FlowBlox.CopyIcon"
           TargetType="{x:Type iconPacks:PackIconMaterial}">
        <Setter Property="Opacity" Value="0.65"/>
        <Setter Property="Foreground" Value="DimGray"/>

        <Style.Triggers>
            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}"
                         Value="True">
                <Setter Property="Opacity" Value="1.0"/>
            </DataTrigger>

            <DataTrigger Binding="{Binding IsPressed, RelativeSource={RelativeSource AncestorType=Button}}"
                         Value="True">
                <Setter Property="Opacity" Value="0.75"/>
            </DataTrigger>

            <DataTrigger Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=Button}}"
                         Value="False">
                <Setter Property="Opacity" Value="0.35"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- ========================================================= -->
    <!-- FlowBlox Toolbar Icon styling (PackIconMaterial)           -->
    <!-- Ensures proper disabled rendering (greyed out)             -->
    <!-- ========================================================= -->

    <!-- Neutral disabled icon brush (professional grey) -->
    <SolidColorBrush x:Key="FlowBlox.Icon.DisabledBrush" Color="#9AA3AF"/>

    <!-- Base style: enabled color comes from the derived style, disabled forces DisabledBrush -->
    <Style x:Key="FlowBlox.ToolbarIconBase"
       TargetType="{x:Type iconPacks:PackIconMaterial}">
        <Setter Property="Width" Value="16"/>
        <Setter Property="Height" Value="16"/>
        <Setter Property="Opacity" Value="1"/>
        <!-- Default enabled foreground (can be overridden by derived styles) -->
        <Setter Property="Foreground" Value="#5C6B73"/>

        <Style.Triggers>
            <!-- IsEnabled is inherited from the parent Button -->
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{StaticResource FlowBlox.Icon.DisabledBrush}"/>
                <Setter Property="Opacity" Value="1"/>
            </Trigger>
        </Style.Triggers>
    </Style>


</ResourceDictionary>