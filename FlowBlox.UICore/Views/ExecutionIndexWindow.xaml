<mah:MetroWindow
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    x:Class="FlowBlox.UICore.Views.ExecutionIndexWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:resources="clr-namespace:FlowBlox.UICore.Resources"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    mc:Ignorable="d"
    Title="{x:Static resources:ExecutionIndexWindow.Title}"
    Width="640"
    Height="320"
    WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/FlowBlox.UICore;component/Views/MahAppMetroResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel Margin="10">
        <Border Background="#FFEEEEEE" DockPanel.Dock="Top" Height="50" Padding="8">
            <StackPanel Orientation="Horizontal">
                <iconPacks:PackIconMaterial Kind="FormatListNumbered"
                                            Width="28"
                                            Height="28"
                                            Margin="0,0,10,0"
                                            VerticalAlignment="Center"
                                            Foreground="DarkSlateGray"/>
                <TextBlock Text="{x:Static resources:ExecutionIndexWindow.Header_Title}"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           FontSize="16" />
            </StackPanel>
        </Border>

        <Border Background="#EDF3F9"
                DockPanel.Dock="Top"
                Padding="12"
                CornerRadius="4"
                Margin="0,8,0,8">
            <TextBlock Text="{x:Static resources:ExecutionIndexWindow.Header_Description}"
                       Foreground="DarkSlateGray"
                       TextWrapping="Wrap" />
        </Border>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,6,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{x:Static resources:ExecutionIndexWindow.Label_ExecutionIndex}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>

                <TextBox x:Name="ExecutionIndexTextBox"
                         Grid.Column="1"
                         Height="32"
                         VerticalContentAlignment="Center"
                         PreviewTextInput="ExecutionIndexTextBox_PreviewTextInput"
                         TextChanged="ExecutionIndexTextBox_TextChanged"/>
            </Grid>

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,10,0,0">
                <Button Margin="0,0,6,0"
                        IsCancel="True"
                        Click="BackButton_Click">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="ArrowLeft"
                                                        Width="14"
                                                        Height="14"
                                                        Margin="0,0,6,0"
                                                        Foreground="#555"/>
                            <TextBlock Text="{x:Static resources:ExecutionIndexWindow.Button_Back}"/>
                        </StackPanel>
                    </Button.Content>
                </Button>

                <Button Margin="0,0,6,0"
                        Click="RemoveExecutionIndexButton_Click">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="DeleteSweep"
                                                        Width="14"
                                                        Height="14"
                                                        Margin="0,0,6,0"
                                                        Foreground="#B22222"/>
                            <TextBlock Text="{x:Static resources:ExecutionIndexWindow.Button_Remove}"/>
                        </StackPanel>
                    </Button.Content>
                </Button>

                <Button x:Name="ApplyButton"
                        IsDefault="True"
                        Click="ApplyButton_Click">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Check"
                                                        Width="14"
                                                        Height="14"
                                                        Margin="0,0,6,0"
                                                        Foreground="#2E7D32"/>
                            <TextBlock Text="{x:Static resources:ExecutionIndexWindow.Button_Apply}"/>
                        </StackPanel>
                    </Button.Content>
                </Button>
            </StackPanel>
        </Grid>
    </DockPanel>
</mah:MetroWindow>
