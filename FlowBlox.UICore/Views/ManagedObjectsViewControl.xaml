<UserControl x:Class="FlowBlox.UICore.Views.ManagedObjectsViewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:converters="clr-namespace:FlowBlox.UICore.Converters"
             xmlns:resources="clr-namespace:FlowBlox.UICore.Resources"
             xmlns:viewModels="clr-namespace:FlowBlox.UICore.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="520"
             d:DesignWidth="900">

    <UserControl.DataContext>
        <viewModels:ManagedObjectsViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/FlowBlox.UICore;component/Views/Styles/FlowBloxCustomStyles.xaml" />
                <ResourceDictionary Source="/FlowBlox.UICore;component/Views/Styles/HostedControlStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <converters:CountToVisibilityConverter x:Key="CountToVisibilityConverter" />

            <Style x:Key="ManagedObjects.ToolbarButtonStyle" TargetType="{x:Type Button}">
                <Setter Property="Width" Value="28" />
                <Setter Property="Height" Value="28" />
                <Setter Property="Margin" Value="0,0,6,0" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Background" Value="#FFF3F6FA" />
                <Setter Property="BorderBrush" Value="#FFD1D9E2" />
                <Setter Property="BorderThickness" Value="1" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#FFE9EEF4" />
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter Property="Background" Value="#FFDDE6F0" />
                    </Trigger>
                </Style.Triggers>
            </Style>

        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderThickness="1" BorderBrush="#FFD4DEE9" CornerRadius="6" Background="#FFF9FBFD">
                <TreeView ItemsSource="{Binding TypeNodes}" SelectedItemChanged="TypeTreeView_SelectedItemChanged" BorderThickness="0" Margin="6">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                        </Style>
                    </TreeView.ItemContainerStyle>
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="{Binding Icon}" Width="16" Height="16" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </Border>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#FFE2E8EF" />

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        BorderThickness="1"
                        BorderBrush="#FFD4DEE9"
                        CornerRadius="6"
                        Background="#FFF9FBFD"
                        Padding="4"
                        Margin="0,0,0,6">
                    <ToolBarTray Background="Transparent" IsLocked="True">
                        <ToolBar Background="Transparent" BorderThickness="0" Padding="0" Margin="0">
                            <Button Command="{Binding AddCommand}"
                                    Style="{StaticResource ManagedObjects.ToolbarButtonStyle}"
                                    ToolTip="{x:Static resources:ManagedObjectsView.Toolbar_Add_Tooltip}">
                                <iconPacks:PackIconMaterial Kind="Plus" Style="{StaticResource HostedControlToolbarIconBase}" />
                            </Button>

                            <Button Command="{Binding EditCommand}"
                                    Style="{StaticResource ManagedObjects.ToolbarButtonStyle}"
                                    ToolTip="{x:Static resources:ManagedObjectsView.Toolbar_Edit_Tooltip}">
                                <iconPacks:PackIconMaterial Kind="Pencil" Style="{StaticResource HostedControlToolbarIconBase}" />
                            </Button>

                            <Button Command="{Binding DeleteCommand}"
                                    Style="{StaticResource ManagedObjects.ToolbarButtonStyle}"
                                    ToolTip="{x:Static resources:ManagedObjectsView.Toolbar_Delete_Tooltip}">
                                <iconPacks:PackIconMaterial Kind="DeleteOutline" Style="{StaticResource HostedControlToolbarIconBase}" />
                            </Button>

                            <Button Command="{Binding RefreshCommand}"
                                    Style="{StaticResource ManagedObjects.ToolbarButtonStyle}"
                                    ToolTip="{x:Static resources:ManagedObjectsView.Toolbar_Refresh_Tooltip}">
                                <iconPacks:PackIconMaterial Kind="Refresh" Style="{StaticResource HostedControlToolbarIconBase}" />
                            </Button>

                            <Menu VerticalAlignment="Center"
                                  Margin="4,0,0,0"
                                  IsEnabled="{Binding HasSelectedEntryActions}">
                                <MenuItem Header="{x:Static resources:ManagedObjectsView.Toolbar_Actions}"
                                          FontSize="12"
                                          ItemsSource="{Binding SelectedEntryActions}">
                                    <MenuItem.ItemContainerStyle>
                                        <Style TargetType="MenuItem">
                                            <Setter Property="Header" Value="{Binding}" />
                                            <Setter Property="HeaderTemplate">
                                                <Setter.Value>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Image Source="{Binding Icon}" Width="14" Height="14" Margin="0,0,6,0" />
                                                            <TextBlock Text="{Binding DisplayName}" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="Command" Value="{Binding Command}"/>
                                            <Setter Property="IsEnabled" Value="{Binding IsEnabled}"/>
                                        </Style>
                                    </MenuItem.ItemContainerStyle>
                                </MenuItem>
                            </Menu>
                        </ToolBar>
                    </ToolBarTray>
                </Border>

                <Border Grid.Row="1" BorderThickness="1" BorderBrush="#FFD4DEE9" CornerRadius="6" Background="White" Padding="6">
                    <ListView x:Name="ManagedObjectsListView"
                              ItemsSource="{Binding ManagedObjects}"
                              SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                              BorderThickness="0"
                              SelectionMode="Single"
                              PreviewMouseRightButtonDown="ManagedObjectsListView_PreviewMouseRightButtonDown">
                        <ListView.Resources>
                            <Style TargetType="GridViewColumnHeader">
                                <Setter Property="HorizontalContentAlignment" Value="Left" />
                                <Setter Property="Padding" Value="8,0,0,0" />
                            </Style>
                        </ListView.Resources>
                        <ListView.ContextMenu>
                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                <MenuItem Header="{x:Static resources:ManagedObjectsView.Toolbar_Add_Tooltip}"
                                          Command="{Binding AddCommand}">
                                    <MenuItem.Icon>
                                        <iconPacks:PackIconMaterial Kind="Plus" Width="14" Height="14" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="{x:Static resources:ManagedObjectsView.Toolbar_Edit_Tooltip}"
                                          Command="{Binding EditCommand}">
                                    <MenuItem.Icon>
                                        <iconPacks:PackIconMaterial Kind="Pencil" Width="14" Height="14" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="{x:Static resources:ManagedObjectsView.Toolbar_Delete_Tooltip}"
                                          Command="{Binding DeleteCommand}">
                                    <MenuItem.Icon>
                                        <iconPacks:PackIconMaterial Kind="DeleteOutline" Width="14" Height="14" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="{x:Static resources:ManagedObjectsView.Toolbar_Refresh_Tooltip}"
                                          Command="{Binding RefreshCommand}">
                                    <MenuItem.Icon>
                                        <iconPacks:PackIconMaterial Kind="Refresh" Width="14" Height="14" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator />
                                <MenuItem Header="{x:Static resources:ManagedObjectsView.Toolbar_Actions}"
                                          IsEnabled="{Binding HasSelectedEntryActions}"
                                          ItemsSource="{Binding SelectedEntryActions}">
                                    <MenuItem.ItemContainerStyle>
                                        <Style TargetType="MenuItem">
                                            <Setter Property="Header" Value="{Binding}" />
                                            <Setter Property="HeaderTemplate">
                                                <Setter.Value>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Image Source="{Binding Icon}" Width="14" Height="14" Margin="0,0,6,0" />
                                                            <TextBlock Text="{Binding DisplayName}" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="Command" Value="{Binding Command}" />
                                            <Setter Property="IsEnabled" Value="{Binding IsEnabled}" />
                                        </Style>
                                    </MenuItem.ItemContainerStyle>
                                </MenuItem>
                            </ContextMenu>
                        </ListView.ContextMenu>

                        <ListView.View>
                            <GridView>
                                <GridViewColumn Width="32">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Image Source="{Binding Icon}" Width="16" Height="16"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn Header="{x:Static resources:ManagedObjectsView.Col_Name}" Width="220" DisplayMemberBinding="{Binding Name}"/>
                                <GridViewColumn Header="{x:Static resources:ManagedObjectsView.Col_DisplayableProperties}" Width="330" DisplayMemberBinding="{Binding DisplayableProperties}"/>
                                <GridViewColumn Header="{x:Static resources:ManagedObjectsView.Col_UsedIn}" Width="320" DisplayMemberBinding="{Binding UsedIn}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Border>

                <Border Grid.Row="1"
                        IsHitTestVisible="False"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Top"
                        Margin="24,56,24,0"
                        Visibility="{Binding ManagedObjects.Count, Converter={StaticResource CountToVisibilityConverter}, ConverterParameter=Reverse}">
                    <Grid VerticalAlignment="Top">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <iconPacks:PackIconMaterial Kind="InformationOutline"
                                                    Margin="0,0,8,0"
                                                    VerticalAlignment="Top"
                                                    Style="{StaticResource FlowBlox.EmptyStateIconStyle}" />
                        <TextBlock Grid.Column="1"
                                   TextAlignment="Left"
                                   Text="{x:Static resources:ManagedObjectsView.EmptyState_NoManagedObjects}"
                                   Style="{StaticResource FlowBlox.EmptyStateTextStyle}" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>

