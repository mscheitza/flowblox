<mah:MetroWindow  
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    x:Class="FlowBlox.UICore.Views.InsightWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModel="clr-namespace:FlowBlox.UICore.ViewModels"
    xmlns:converters="clr-namespace:FlowBlox.UICore.Converters.Insight"
    xmlns:iconPacks="clr-namespace:MahApps.Metro.IconPacks;assembly=MahApps.Metro.IconPacks"
    xmlns:resources="clr-namespace:FlowBlox.UICore.Resources"
    Title="{x:Static resources:InsightWindow.InsightWindow_Title}" Height="450" Width="800"
    mc:Ignorable="d">

    <Window.DataContext>
        <viewModel:InsightViewModel />
    </Window.DataContext>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/FlowBlox.UICore;component/Views/MahAppMetroResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <converters:DatasetStatusIconMultiConverter x:Key="DatasetStatusIconMultiConverter" />
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <DataGrid x:Name="dataGrid" AutoGenerateColumns="False" ItemsSource="{Binding FlowBlockOutDatasets}"
                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="0"
                  IsReadOnly="True" SelectionMode="Extended" SelectionUnit="CellOrRowHeader">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="{x:Static resources:InsightWindow.DataGrid_Column_Status}" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <iconPacks:PackIconControl ToolTip="{x:Static resources:InsightWindow.ToolTip_Status}" Width="20" Height="20" VerticalAlignment="Center">
                                <iconPacks:PackIconControl.Kind>
                                    <MultiBinding Converter="{StaticResource DatasetStatusIconMultiConverter}">
                                        <Binding />
                                        <Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType={x:Type DataGrid}}" />
                                    </MultiBinding>
                                </iconPacks:PackIconControl.Kind>
                            </iconPacks:PackIconControl>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</mah:MetroWindow>
