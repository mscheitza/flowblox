<UserControl x:Class="FlowBlox.UICore.Views.AIAssistantControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:resources="clr-namespace:FlowBlox.UICore.Resources"
             xmlns:viewModels="clr-namespace:FlowBlox.UICore.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="450">
    <UserControl.DataContext>
        <viewModels:AIAssistantViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/FlowBlox.UICore;component/Views/Styles/FlowBloxCustomStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#FFEEEEEE"
                Height="48"
                Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{x:Static resources:AIAssistantControl.Header_Title}"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           FontSize="16" />

                <Button Grid.Column="1"
                        Width="32"
                        Height="32"
                        Padding="0"
                        Margin="8,0,0,0"
                        HorizontalAlignment="Right"
                        ToolTip="{x:Static resources:AIAssistantControl.Tooltip_Undo}"
                        BorderThickness="0"
                        Background="Transparent"
                        Command="{Binding UndoProjectStateCommand}">
                    <iconPacks:PackIconMaterial Kind="Undo"
                                                Width="18"
                                                Height="18"
                                                Style="{StaticResource FlowBlox.ToolbarIconBase}" />
                </Button>

                <Button Grid.Column="2"
                        Width="32"
                        Height="32"
                        Padding="0"
                        Margin="4,0,0,0"
                        HorizontalAlignment="Right"
                        ToolTip="{x:Static resources:AIAssistantControl.Tooltip_Redo}"
                        BorderThickness="0"
                        Background="Transparent"
                        Command="{Binding RedoProjectStateCommand}">
                    <iconPacks:PackIconMaterial Kind="Redo"
                                                Width="18"
                                                Height="18"
                                                Style="{StaticResource FlowBlox.ToolbarIconBase}" />
                </Button>

                <Button Grid.Column="3"
                        Width="32"
                        Height="32"
                        Padding="0"
                        Margin="4,0,0,0"
                        HorizontalAlignment="Right"
                        ToolTip="{x:Static resources:AIAssistantControl.Tooltip_OpenCommunicationProtocolDirectory}"
                        BorderThickness="0"
                        Background="Transparent"
                        Command="{Binding OpenCommunicationProtocolDirectoryCommand}">
                    <iconPacks:PackIconMaterial Kind="FolderOpenOutline"
                                                Width="18"
                                                Height="18"
                                                Style="{StaticResource FlowBlox.ToolbarIconBase}" />
                </Button>

                <Button x:Name="SettingsButton"
                        Grid.Column="5"
                        Width="32"
                        Height="32"
                        Padding="0"
                        Margin="4,0,0,0"
                        HorizontalAlignment="Right"
                        ToolTip="{x:Static resources:AIAssistantControl.Tooltip_Configure}"
                        BorderThickness="0"
                        Background="Transparent">
                    <iconPacks:PackIconMaterial Kind="CogOutline"
                                                Width="18"
                                                Height="18"
                                                Style="{StaticResource FlowBlox.ToolbarIconBase}" />
                </Button>

                <Button Grid.Column="4"
                        Width="32"
                        Height="32"
                        Padding="0"
                        Margin="4,0,0,0"
                        HorizontalAlignment="Right"
                        ToolTip="{x:Static resources:AIAssistantControl.Tooltip_ResetCommunicationState}"
                        BorderThickness="0"
                        Background="Transparent"
                        Command="{Binding ResetCommunicationStateCommand}">
                    <iconPacks:PackIconMaterial Kind="Refresh"
                                                Width="18"
                                                Height="18"
                                                Style="{StaticResource FlowBlox.ToolbarIconBase}" />
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="#EDF3F9"
                Padding="10"
                CornerRadius="4"
                Margin="0,8,0,8">
            <TextBlock Text="{x:Static resources:AIAssistantControl.Header_Description}"
                       Foreground="DarkSlateGray"
                       TextWrapping="Wrap" />
        </Border>

        <Border Grid.Row="2"
                Background="#FFFFFFFF"
                BorderBrush="#FFD0D0D0"
                BorderThickness="1"
                CornerRadius="10"
                Padding="6">
            <Grid>
                <ListBox ItemsSource="{Binding Transcript}"
                         BorderThickness="0"
                         Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Text}"
                                       TextWrapping="Wrap"
                                       Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}">
                                <TextBlock.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="{x:Static resources:AIAssistantControl.ContextMenu_Copy}"
                                                  Command="{Binding PlacementTarget.Tag.CopyTranscriptEntryCommand, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}">
                                            <MenuItem.Icon>
                                                <iconPacks:PackIconMaterial Kind="ContentCopy" Width="16" Height="16" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="{x:Static resources:AIAssistantControl.ContextMenu_OpenInEditor}"
                                                  Command="{Binding PlacementTarget.Tag.OpenTranscriptEntryInEditorCommand, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}">
                                            <MenuItem.Icon>
                                                <iconPacks:PackIconMaterial Kind="OpenInNew" Width="16" Height="16" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                    </ContextMenu>
                                </TextBlock.ContextMenu>
                            </TextBlock>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel IsHitTestVisible="False"
                            Opacity="0.16"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <iconPacks:PackIconMaterial Kind="RobotOutline"
                                                Width="84"
                                                Height="84"
                                                Foreground="#FF666666"
                                                HorizontalAlignment="Center" />
                    <TextBlock Text="{x:Static resources:AIAssistantControl.Watermark_Title}"
                               Foreground="#FF666666"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Margin="0,8,0,8"
                Background="#FFFFFFFF"
                BorderBrush="#FFD0D0D0"
                BorderThickness="1"
                CornerRadius="10"
                Padding="6">
            <TextBox x:Name="PromptTextBox"
                     Height="180"
                     MinHeight="120"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     BorderThickness="0"
                     Background="Transparent"
                     IsEnabled="{Binding CanEditInput}"
                     Text="{Binding CurrentInput, UpdateSourceTrigger=PropertyChanged}" />
        </Border>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="{x:Static resources:AIAssistantControl.Button_Submit}"
                    MinWidth="90"
                    Margin="0,0,8,0"
                    Command="{Binding SubmitCommand}" />
            <Button Content="{x:Static resources:AIAssistantControl.Button_Cancel}"
                    MinWidth="90"
                    Command="{Binding CancelCommand}" />
        </StackPanel>
    </Grid>
</UserControl>
