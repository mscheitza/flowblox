<mah:MetroWindow
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    x:Class="FlowBlox.UICore.Views.LoginWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:FlowBlox.UICore.Converters"
    xmlns:resources="clr-namespace:FlowBlox.UICore.Resources"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    Title="{x:Static resources:LoginWindow.LoginWindow_Title}"
    Height="520"
    Width="420"
    WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/FlowBlox.UICore;component/Views/MahAppMetroResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel Margin="10">

        <!-- Header -->
        <Border Background="#FFEEEEEE"
                DockPanel.Dock="Top"
                Height="50"
                Padding="8">
            <StackPanel Orientation="Horizontal">
                <iconPacks:PackIconMaterial Kind="LoginVariant"
                                            Width="24"
                                            Height="24"
                                            Margin="0,0,10,0"
                                            VerticalAlignment="Center"
                                            Foreground="DarkSlateGray"/>
                <TextBlock Text="{x:Static resources:LoginWindow.Header_Title}"
                           FontWeight="Bold"
                           FontSize="16"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Description -->
        <Border Background="#EDF3F9"
                DockPanel.Dock="Top"
                Padding="12"
                CornerRadius="4"
                Margin="0,8,0,12">
            <TextBlock Text="{x:Static resources:LoginWindow.Header_Description}"
                       FontWeight="UltraLight"
                       Foreground="DarkSlateGray"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- Content -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>

                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>

                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>

                <RowDefinition Height="Auto"/>

                <RowDefinition Height="Auto"/>

                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- API URL -->
            <Label Content="{x:Static resources:LoginWindow.Label_ApiUrl}" Grid.Row="0"/>
            <ComboBox Grid.Row="1"
                      Margin="0,5,0,10"
                      ItemsSource="{Binding ApiUrls}"
                      SelectedItem="{Binding SelectedApiUrl}"
                      IsEnabled="{Binding IsApiUrlSelectionEnabled}"
                      MinHeight="28"/>

            <!-- Email -->
            <Label Content="{x:Static resources:LoginWindow.Label_Email}" Grid.Row="2"/>
            <TextBox Text="{Binding Email}" Grid.Row="3" Margin="0,5,0,10"/>

            <!-- Password -->
            <Label Content="{x:Static resources:LoginWindow.Label_Password}" Grid.Row="4"/>
            <PasswordBox x:Name="PasswordBox"
                         PasswordChanged="PasswordBox_PasswordChanged"
                         Grid.Row="5"
                         Margin="0,5,0,10"/>

            <!-- Save -->
            <CheckBox Content="{x:Static resources:LoginWindow.CheckBox_SaveCredentials}"
                      IsChecked="{Binding SaveUserCredentials}"
                      HorizontalAlignment="Right"
                      Grid.Row="6"
                      Margin="0,0,0,10"/>

            <!-- Forgot -->
            <TextBlock Grid.Row="7"
                       HorizontalAlignment="Right"
                       Margin="0,0,0,10"
                       Visibility="{Binding CanResetPassword, Converter={StaticResource BoolToVisibilityConverter}}">
                <Hyperlink Command="{Binding ForgotPasswordCommand}"
                           Foreground="SteelBlue">
                    <Run Text="{x:Static resources:LoginWindow.Link_ForgotPassword}" />
                </Hyperlink>
            </TextBlock>


            <!-- Buttons -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Grid.Row="8"
                        Margin="0,10,0,0">
                <Button Command="{Binding CancelCommand}"
                        Content="{x:Static resources:LoginWindow.Button_Back}"
                        Margin="0,0,10,0"
                        IsCancel="True"/>
                <Button Command="{Binding LoginCommand}"
                        Content="{x:Static resources:LoginWindow.Button_Login}"
                        IsDefault="True"/>
            </StackPanel>
        </Grid>
    </DockPanel>
</mah:MetroWindow>
