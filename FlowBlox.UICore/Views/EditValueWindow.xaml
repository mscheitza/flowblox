<mah:MetroWindow
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    x:Class="FlowBlox.UICore.Views.EditValueWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:resources="clr-namespace:FlowBlox.UICore.Resources"
    mc:Ignorable="d"
    Title="{x:Static resources:EditValueWindow.Title}"
    Width="700"
    Height="200"
    WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/FlowBlox.UICore;component/Views/MahAppMetroResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="DescriptionTextBlock"
                   Grid.Row="0"
                   Text="{x:Static resources:EditValueWindow.DefaultDescription}"
                   Margin="0,0,0,8"
                   TextWrapping="Wrap"/>

        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="ParameterLabel"
                       Grid.Column="0"
                       Text="{x:Static resources:EditValueWindow.LabelParameter}"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"
                       Visibility="Collapsed"/>
            <TextBlock x:Name="ParameterValueTextBlock"
                       Grid.Column="1"
                       VerticalAlignment="Center"
                       Visibility="Collapsed"
                       FontWeight="SemiBold"/>
        </Grid>

        <Grid Grid.Row="2">
            <TextBox x:Name="ValueTextBox"
                     AcceptsReturn="False"
                     VerticalScrollBarVisibility="Disabled"
                     HorizontalScrollBarVisibility="Disabled"
                     TextWrapping="NoWrap"
                     Height="32"
                     TextChanged="ValueInput_Changed"/>
            <ComboBox x:Name="SuggestionsComboBox"
                      Visibility="Collapsed"
                      IsEditable="True"
                      IsTextSearchEnabled="True"
                      Height="32"
                      SelectionChanged="ValueInput_Changed"/>
        </Grid>

        <DockPanel Grid.Row="3" Margin="0,10,0,0" LastChildFill="False">
            <CheckBox x:Name="MaskRegexCheckBox"
                      Content="{x:Static resources:EditValueWindow.MaskRegex}"
                      VerticalAlignment="Center"
                      DockPanel.Dock="Left"
                      Visibility="Collapsed"/>

            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <Button Width="100"
                        Margin="0,0,8,0"
                        IsCancel="True"
                        Click="CancelButton_Click"
                        Content="{x:Static resources:EditValueWindow.ButtonCancel}"/>
                <Button x:Name="ApplyButton"
                        Width="100"
                        IsDefault="True"
                        Click="ApplyButton_Click"
                        Content="{x:Static resources:EditValueWindow.ButtonApply}"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</mah:MetroWindow>
