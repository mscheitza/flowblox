<mah:MetroWindow
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    x:Class="FlowBlox.UICore.Views.RegistrationWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:resources="clr-namespace:FlowBlox.UICore.Resources"
    xmlns:converters="clr-namespace:FlowBlox.UICore.Converters"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    Title="{x:Static resources:RegistrationWindow.Title}"
    Height="560"
    Width="650"
    DataContext="{Binding RelativeSource={RelativeSource Self}}"
    WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/FlowBlox.UICore;component/Views/MahAppMetroResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel Margin="10">

        <!-- Header -->
        <Border Background="#FFEEEEEE" DockPanel.Dock="Top" Height="50" Padding="8">
            <StackPanel Orientation="Horizontal">
                <iconPacks:PackIconMaterial Kind="AccountPlusOutline"
                                            Width="32"
                                            Height="32"
                                            Margin="0,0,10,0"
                                            VerticalAlignment="Center"
                                            Foreground="DarkSlateGray"/>
                <TextBlock Text="{x:Static resources:RegistrationWindow.Header_Title}"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           FontSize="16" />
            </StackPanel>
        </Border>

        <!-- Description -->
        <Border Background="#EDF3F9"
                DockPanel.Dock="Top"
                Padding="12"
                CornerRadius="4"
                Margin="0,8,0,8">
            <TextBlock Text="{x:Static resources:RegistrationWindow.Header_Description}"
                       FontWeight="UltraLight"
                       Foreground="DarkSlateGray"
                       TextWrapping="Wrap" />
        </Border>

        <!-- Content + Error Footer + Buttons -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Content -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Left Column -->
                <StackPanel Grid.Column="0" Margin="10">

                    <Label Content="{x:Static resources:RegistrationWindow.Label_FirstName}" HorizontalAlignment="Left" Margin="0,5,0,0" />
                    <TextBox Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}"
                             mah:TextBoxHelper.Watermark="{x:Static resources:RegistrationWindow.Placeholder_FirstName}" />

                    <Label Content="{x:Static resources:RegistrationWindow.Label_LastName}" HorizontalAlignment="Left" Margin="0,5,0,0" />
                    <TextBox Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}"
                             mah:TextBoxHelper.Watermark="{x:Static resources:RegistrationWindow.Placeholder_LastName}" />

                    <Label Content="{x:Static resources:RegistrationWindow.Label_UserName}" HorizontalAlignment="Left" Margin="0,5,0,0" />
                    <TextBox Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}"
                             mah:TextBoxHelper.Watermark="{x:Static resources:RegistrationWindow.Placeholder_UserName}"
                             ToolTip="{x:Static resources:RegistrationWindow.Tooltip_UserName}" />

                    <!-- Email (Required) -->
                    <Label HorizontalAlignment="Left" Margin="0,5,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{x:Static resources:RegistrationWindow.Label_Email}" />
                            <iconPacks:PackIconMaterial Kind="Asterisk"
                                                        Width="9"
                                                        Height="9"
                                                        Margin="6,1,0,0"
                                                        Foreground="IndianRed"
                                                        VerticalAlignment="Center"/>
                        </StackPanel>
                    </Label>
                    <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" />

                    <Label HorizontalAlignment="Left" Margin="0,5,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{x:Static resources:RegistrationWindow.Label_EmailRepeat}" />
                            <iconPacks:PackIconMaterial Kind="Asterisk"
                                        Width="9"
                                        Height="9"
                                        Margin="5,2,0,0"
                                        Foreground="IndianRed"
                                        VerticalAlignment="Center"/>
                        </StackPanel>
                    </Label>
                    <TextBox Text="{Binding EmailRepeat, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <!-- Right Column -->
                <StackPanel Grid.Column="1" Margin="10">

                    <!-- Password (Required) -->
                    <Label HorizontalAlignment="Left" Margin="0,5,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{x:Static resources:RegistrationWindow.Label_Password}" />
                            <iconPacks:PackIconMaterial Kind="Asterisk"
                                                        Width="9"
                                                        Height="9"
                                                        Margin="6,1,0,0"
                                                        Foreground="IndianRed"
                                                        VerticalAlignment="Center"/>
                        </StackPanel>
                    </Label>
                    <PasswordBox x:Name="passwordBox"
                                 PasswordChanged="PasswordBox_PasswordChanged"
                                 mah:TextBoxHelper.Watermark="{x:Static resources:RegistrationWindow.Label_Password}" />

                    <Label HorizontalAlignment="Left" Margin="0,5,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{x:Static resources:RegistrationWindow.Label_PasswordRepeat}" />
                            <iconPacks:PackIconMaterial Kind="Asterisk"
                                        Width="9"
                                        Height="9"
                                        Margin="5,2,0,0"
                                        Foreground="IndianRed"
                                        VerticalAlignment="Center"/>
                        </StackPanel>
                    </Label>
                    <PasswordBox x:Name="passwordRepeatBox"
                                 PasswordChanged="PasswordRepeatBox_PasswordChanged"
                                 mah:TextBoxHelper.Watermark="{x:Static resources:RegistrationWindow.Label_PasswordRepeat}" />

                    <Label Content="{x:Static resources:RegistrationWindow.Label_Captcha}" HorizontalAlignment="Left" Margin="0,5,0,0" />
                    <Image Source="{Binding CaptchaResponse.CaptchaImage}"
                           Margin="0,5,0,0"
                           Height="40"
                           Width="140"
                           HorizontalAlignment="Left"
                           Stretch="None" />

                    <Label Content="{x:Static resources:RegistrationWindow.Label_CaptchaCode}" HorizontalAlignment="Left" Margin="0,5,0,0" />
                    <TextBox Text="{Binding CaptchaCode, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </Grid>

            <!-- Error footer (between content and buttons, no layout-jump) -->
            <Border Grid.Row="1"
                    Background="#FFFCE8E8"
                    BorderBrush="#FFE6A3A3"
                    BorderThickness="1"
                    Padding="12"
                    CornerRadius="4"
                    Margin="0,6,0,0"
                    Visibility="{Binding ErrorText, Converter={StaticResource NullToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <iconPacks:PackIconMaterial Kind="AlertCircleOutline"
                                                Width="18"
                                                Height="18"
                                                Margin="0,2,10,0"
                                                Foreground="#FF8A1F1F"
                                                VerticalAlignment="Top"/>

                    <TextBlock Grid.Column="1"
                               Text="{Binding ErrorText}"
                               FontWeight="UltraLight"
                               Foreground="#FF8A1F1F"
                               TextWrapping="Wrap" />
                </Grid>
            </Border>

            <!-- Buttons -->
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,10,0,0">
                <Button Content="{x:Static resources:RegistrationWindow.Button_Back}"
                        Padding="5,0,5,0"
                        Margin="5,0,5,0"
                        Command="{Binding CloseCommand}" />
                <Button Content="{x:Static resources:RegistrationWindow.Button_Register}"
                        Padding="5,0,5,0"
                        Command="{Binding RegisterCommand}"
                        IsEnabled="{Binding CanRegister}" />
            </StackPanel>
        </Grid>
    </DockPanel>
</mah:MetroWindow>

