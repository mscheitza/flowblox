<mah:MetroWindow
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    x:Class="FlowBlox.UICore.Views.RegistrationWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:resources="clr-namespace:FlowBlox.UICore.Resources"
    Title="{x:Static resources:RegistrationWindow.Title}" 
    Height="450"
    Width="650"
    DataContext="{Binding RelativeSource={RelativeSource Self}}"
    WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/FlowBlox.UICore;component/Views/MahAppMetroResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Column="0" Grid.Row="0" Margin="10">
            <Label Content="{x:Static resources:RegistrationWindow.Label_FirstName}" HorizontalAlignment="Left" Margin="0,5,0,0" />
            <TextBox Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}" />

            <Label Content="{x:Static resources:RegistrationWindow.Label_LastName}" HorizontalAlignment="Left" Margin="0,5,0,0" />
            <TextBox Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}" />

            <Label Content="{x:Static resources:RegistrationWindow.Label_UserName}" HorizontalAlignment="Left" Margin="0,5,0,0" />
            <TextBox Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}" />

            <Label Content="{x:Static resources:RegistrationWindow.Label_Email}" HorizontalAlignment="Left" Margin="0,5,0,0" />
            <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" />

            <Label Content="{x:Static resources:RegistrationWindow.Label_EmailRepeat}" HorizontalAlignment="Left" Margin="0,5,0,0" />
            <TextBox Text="{Binding EmailRepeat, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>

        <StackPanel Grid.Column="1" Grid.Row="0" Margin="10">
            <Label Content="{x:Static resources:RegistrationWindow.Label_Password}" HorizontalAlignment="Left" Margin="0,5,0,0" />
            <PasswordBox x:Name="passwordBox" PasswordChanged="PasswordBox_PasswordChanged" />

            <Label Content="{x:Static resources:RegistrationWindow.Label_PasswordRepeat}" HorizontalAlignment="Left" Margin="0,5,0,0" />
            <PasswordBox x:Name="passwordRepeatBox" PasswordChanged="PasswordRepeatBox_PasswordChanged" />

            <Label Content="{x:Static resources:RegistrationWindow.Label_Captcha}" HorizontalAlignment="Left" Margin="0,5,0,0" />
            <Image Source="{Binding CaptchaResponse.CaptchaImage}" Margin="0,5,0,0" Height="40" Width="140" HorizontalAlignment="Left" Stretch="None" />

            <Label Content="{x:Static resources:RegistrationWindow.Label_CaptchaCode}" HorizontalAlignment="Left" Margin="0,5,0,0" />
            <TextBox Text="{Binding CaptchaCode, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>

        <TextBlock Grid.ColumnSpan="2" Grid.Row="1"
                   Text="{Binding ErrorText}"
                   Foreground="Red"
                   Margin="0,5,0,0"
                   TextWrapping="Wrap" />

        <StackPanel Grid.ColumnSpan="2" Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Content="{x:Static resources:RegistrationWindow.Button_Back}"
                    Padding="5,0,5,0"
                    Margin="5,0,5,0"
                    Command="{Binding CloseCommand}" />
            <Button Content="{x:Static resources:RegistrationWindow.Button_Register}"
                    Padding="5,0,5,0"
                    Command="{Binding RegisterCommand}"
                    IsEnabled="{Binding CanRegister}" />
        </StackPanel>
    </Grid>
</mah:MetroWindow>
