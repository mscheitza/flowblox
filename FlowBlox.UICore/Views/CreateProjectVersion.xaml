<mah:MetroWindow
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    x:Class="FlowBlox.UICore.Views.CreateProjectVersionWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:resources="clr-namespace:FlowBlox.UICore.Resources"
    xmlns:converters="clr-namespace:FlowBlox.UICore.Converters"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    Title="{x:Static resources:CreateProjectVersionWindow.Title}"
    Width="720"
    Height="520"
    WindowStartupLocation="CenterOwner"
    ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/FlowBlox.UICore;component/Views/MahAppMetroResources.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel Margin="10">

        <!-- Header -->
        <Border Background="#FFEEEEEE"
                DockPanel.Dock="Top"
                Height="50"
                Padding="8">
            <StackPanel Orientation="Horizontal">
                <iconPacks:PackIconMaterial Kind="SourceBranchPlus"
                                            Width="30"
                                            Height="30"
                                            Margin="0,0,10,0"
                                            VerticalAlignment="Center"
                                            Foreground="DarkSlateGray"/>
                <TextBlock Text="{x:Static resources:CreateProjectVersionWindow.Header_Title}"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           FontSize="16" />
            </StackPanel>
        </Border>

        <!-- Description -->
        <Border Background="#EDF3F9"
                DockPanel.Dock="Top"
                Padding="12"
                CornerRadius="4"
                Margin="0,8,0,8">
            <TextBlock Text="{x:Static resources:CreateProjectVersionWindow.Header_Description}"
                       FontWeight="UltraLight"
                       Foreground="DarkSlateGray"
                       TextWrapping="Wrap" />
        </Border>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Margin="0,0,0,6">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0"
                           Content="{x:Static resources:CreateProjectVersionWindow.Label_Comment}"
                           FontWeight="DemiBold"
                           Margin="0,0,0,5" />

                    <TextBox Grid.Row="1"
                             Text="{Binding Comment, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Height="180"
                             Margin="0,0,0,12"
                             mah:TextBoxHelper.Watermark="{x:Static resources:CreateProjectVersionWindow.Placeholder_Comment}" />

                    <Border Grid.Row="2"
                            Background="#FFFAF3D1"
                            BorderBrush="#FFE0C869"
                            BorderThickness="1"
                            Padding="10"
                            CornerRadius="4"
                            Margin="0,4,0,0">
                        <TextBlock Text="{x:Static resources:CreateProjectVersionWindow.Hint_Immutable}"
                                   Foreground="#FF6B5A1E"
                                   TextWrapping="Wrap"/>
                    </Border>

                </Grid>
            </ScrollViewer>

            <!-- Error footer -->
            <Border Grid.Row="1"
                    Background="#FFFCE8E8"
                    BorderBrush="#FFE6A3A3"
                    BorderThickness="1"
                    Padding="12"
                    CornerRadius="4"
                    Margin="0,12,0,0"
                    Visibility="{Binding ErrorText, Converter={StaticResource NullToVisibilityConverter}}">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <iconPacks:PackIconMaterial Kind="AlertCircleOutline"
                                                Width="18"
                                                Height="18"
                                                Margin="0,2,10,0"
                                                Foreground="#FF8A1F1F"
                                                VerticalAlignment="Top"/>

                    <TextBlock Grid.Column="1"
                               Text="{Binding ErrorText}"
                               Foreground="#FF8A1F1F"
                               TextWrapping="Wrap" />
                </Grid>
            </Border>

            <!-- Buttons -->
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,12,0,0">

                <Button Content="{x:Static resources:CreateProjectVersionWindow.Button_Cancel}"
                        Margin="0,0,6,0"
                        Command="{Binding CloseCommand}"
                        IsCancel="True"/>

                <Button Content="{x:Static resources:CreateProjectVersionWindow.Button_Create}"
                        Command="{Binding CreateCommand}"
                        IsEnabled="{Binding CanCreate}"
                        IsDefault="True"/>
            </StackPanel>

        </Grid>
    </DockPanel>
</mah:MetroWindow>
