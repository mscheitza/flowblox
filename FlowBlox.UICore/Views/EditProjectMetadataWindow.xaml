<mah:MetroWindow
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    x:Class="FlowBlox.UICore.Views.EditProjectMetadataWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:resources="clr-namespace:FlowBlox.UICore.Resources"
    xmlns:converters="clr-namespace:FlowBlox.UICore.Converters"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    Title="{x:Static resources:EditProjectMetadataWindow.Title}"
    Width="720"
    Height="520"
    WindowStartupLocation="CenterOwner"
    ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/FlowBlox.UICore;component/Views/MahAppMetroResources.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
            <converters:EnumDisplayNameConverter x:Key="EnumDisplayNameConverter" />
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel Margin="10">

        <!-- Header -->
        <Border Background="#FFEEEEEE"
                DockPanel.Dock="Top"
                Height="50"
                Padding="8">
            <StackPanel Orientation="Horizontal">
                <iconPacks:PackIconMaterial Kind="PencilOutline"
                                            Width="30"
                                            Height="30"
                                            Margin="0,0,10,0"
                                            VerticalAlignment="Center"
                                            Foreground="DarkSlateGray"/>
                <TextBlock Text="{x:Static resources:EditProjectMetadataWindow.Header_Title}"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           FontSize="16" />
            </StackPanel>
        </Border>

        <!-- Description -->
        <Border Background="#EDF3F9"
                DockPanel.Dock="Top"
                Padding="12"
                CornerRadius="4"
                Margin="0,8,0,8">
            <TextBlock Text="{x:Static resources:EditProjectMetadataWindow.Header_Description}"
                       FontWeight="UltraLight"
                       Foreground="DarkSlateGray"
                       TextWrapping="Wrap" />
        </Border>

        <!-- Main layout -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Content -->
            <ScrollViewer Grid.Row="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Margin="0,0,0,6">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Name -->
                    <Label Grid.Row="0"
                           Content="{x:Static resources:EditProjectMetadataWindow.Label_ProjectName}"
                           FontWeight="DemiBold"
                           Margin="0,0,0,5" />

                    <TextBox Grid.Row="1"
                             Text="{Binding ProjectName, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12"
                             mah:TextBoxHelper.Watermark="{x:Static resources:EditProjectMetadataWindow.Placeholder_ProjectName}" />

                    <!-- Description -->
                    <Label Grid.Row="2"
                           Content="{x:Static resources:EditProjectMetadataWindow.Label_ProjectDescription}"
                           FontWeight="DemiBold"
                           Margin="0,0,0,5" />

                    <TextBox Grid.Row="3"
                             Text="{Binding ProjectDescription, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Height="140"
                             Margin="0,0,0,12"
                             mah:TextBoxHelper.Watermark="{x:Static resources:EditProjectMetadataWindow.Placeholder_ProjectDescription}" />

                    <!-- Visibility -->
                    <Label Grid.Row="4"
                           Content="{x:Static resources:EditProjectMetadataWindow.Label_Visibility}"
                           FontWeight="DemiBold"
                           Margin="0,0,0,5" />

                    <ComboBox Grid.Row="5"
                              ItemsSource="{Binding VisibilityValues}"
                              SelectedItem="{Binding Visibility, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource EnumDisplayNameConverter}}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </Grid>
            </ScrollViewer>

            <!-- Error footer -->
            <!-- Displays validation or API errors without overlapping content -->
            <Border Grid.Row="1"
                    Background="#FFFCE8E8"
                    BorderBrush="#FFE6A3A3"
                    BorderThickness="1"
                    Padding="12"
                    CornerRadius="4"
                    Margin="0,12,0,0"
                    Visibility="{Binding ErrorText, Converter={StaticResource NullToVisibilityConverter}}">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <iconPacks:PackIconMaterial Kind="AlertCircleOutline"
                                                Width="18"
                                                Height="18"
                                                Margin="0,2,10,0"
                                                Foreground="#FF8A1F1F"
                                                VerticalAlignment="Top"/>

                    <TextBlock Grid.Column="1"
                               Text="{Binding ErrorText}"
                               Foreground="#FF8A1F1F"
                               TextWrapping="Wrap" />
                </Grid>
            </Border>

            <!-- Buttons -->
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,12,0,0">

                <Button Content="{x:Static resources:EditProjectMetadataWindow.Button_Cancel}"
                        Margin="0,0,6,0"
                        Command="{Binding CloseCommand}" />

                <Button Content="{x:Static resources:EditProjectMetadataWindow.Button_Save}"
                        Command="{Binding SaveCommand}"
                        IsEnabled="{Binding CanSave}" />
            </StackPanel>

        </Grid>
    </DockPanel>
</mah:MetroWindow>
