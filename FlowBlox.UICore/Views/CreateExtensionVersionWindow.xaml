<mah:MetroWindow
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    x:Class="FlowBlox.UICore.Views.CreateExtensionVersionWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:resources="clr-namespace:FlowBlox.UICore.Resources"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    Title="{x:Static resources:CreateExtensionVersionWindow.Title}"
    Height="560"
    Width="760"
    WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/FlowBlox.UICore;component/Views/MahAppMetroResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel Margin="10">
        <Border Background="#FFEEEEEE" DockPanel.Dock="Top" Height="50" Padding="8">
            <StackPanel Orientation="Horizontal">
                <iconPacks:PackIconMaterial Kind="SourceBranchPlus"
                                            Width="30"
                                            Height="30"
                                            Margin="0,0,10,0"
                                            VerticalAlignment="Center"
                                            Foreground="DarkSlateGray"/>
                <TextBlock Text="{x:Static resources:CreateExtensionVersionWindow.Header_Title}"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           FontSize="16"/>
            </StackPanel>
        </Border>

        <Border Background="#EDF3F9"
                DockPanel.Dock="Top"
                Padding="12"
                CornerRadius="4"
                Margin="0,8,0,8">
            <TextBlock Text="{x:Static resources:CreateExtensionVersionWindow.Header_Description}"
                       FontWeight="UltraLight"
                       Foreground="DarkSlateGray"
                       TextWrapping="Wrap"/>
        </Border>

        <ToolBar DockPanel.Dock="Top" Margin="0,0,0,8">
            <Button Command="{Binding ExtractMetadataCommand}"
                    ToolTip="{x:Static resources:CreateExtensionVersionWindow.Toolbar_ExtractMetadata_Tooltip}">
                <Button.Content>
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="FolderSearchOutline" Margin="0,0,5,0"/>
                        <TextBlock Text="{x:Static resources:CreateExtensionVersionWindow.Toolbar_ExtractMetadata}"/>
                    </StackPanel>
                </Button.Content>
            </Button>
        </ToolBar>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                       Text="{x:Static resources:CreateExtensionVersionWindow.Hint_Metadata}"
                       Foreground="Gray"
                       Margin="0,0,0,10"
                       TextWrapping="Wrap"/>

            <TextBlock Grid.Row="1" Grid.Column="0"
                       VerticalAlignment="Center"
                       Text="{x:Static resources:CreateExtensionVersionWindow.Label_AssemblyName}"/>
            <TextBox Grid.Row="1" Grid.Column="1"
                     IsReadOnly="True"
                     mah:TextBoxHelper.Watermark="{x:Static resources:CreateExtensionVersionWindow.Watermark_AssemblyName}"
                     Text="{Binding DetectedAssemblyName}"/>

            <TextBlock Grid.Row="2" Grid.Column="0"
                       Margin="0,10,0,0"
                       VerticalAlignment="Top"
                       Text="{x:Static resources:CreateExtensionVersionWindow.Label_AssemblyDescription}"/>
            <TextBox Grid.Row="2" Grid.Column="1"
                     Margin="0,10,0,0"
                     IsReadOnly="True"
                     MinHeight="70"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     mah:TextBoxHelper.Watermark="{x:Static resources:CreateExtensionVersionWindow.Watermark_Description}"
                     Text="{Binding DetectedDescription}"/>

            <TextBlock Grid.Row="3" Grid.Column="0"
                       Margin="0,10,0,0"
                       VerticalAlignment="Center"
                       Text="{x:Static resources:CreateExtensionVersionWindow.Label_Version}"/>
            <TextBox Grid.Row="3" Grid.Column="1"
                     Margin="0,10,0,0"
                     Text="{Binding Version, UpdateSourceTrigger=PropertyChanged}"
                     mah:TextBoxHelper.Watermark="{x:Static resources:CreateExtensionVersionWindow.Watermark_Version}"
                     ToolTip="{x:Static resources:CreateExtensionVersionWindow.ToolTip_Format}"/>

            <StackPanel Grid.Row="5"
                        Grid.ColumnSpan="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,20,0,0">
                <Button Content="{x:Static resources:CreateExtensionVersionWindow.Button_Cancel}"
                        Command="{Binding CancelCommand}"
                        Margin="0,0,10,0"
                        IsCancel="True"/>
                <Button Content="{x:Static resources:CreateExtensionVersionWindow.Button_Create}"
                        Command="{Binding CreateCommand}"
                        IsEnabled="{Binding CanCreate}"
                        IsDefault="True"/>
            </StackPanel>
        </Grid>
    </DockPanel>
</mah:MetroWindow>
