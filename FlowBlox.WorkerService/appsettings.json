{
  "FlowBloxService": {
    "ServiceName": "FlowBlox.Service",
    "DisplayName": "FlowBlox Project Service",
    "Description": "Executes a FlowBlox project in the background using FlowBlox.Core.Runner.",
    "RunOnStart": true,

    "ProjectFile": "%Options::General.ProjectDir%\\MyProject.fbprj",

    "ProjectSpaceGuid": null,
    "ProjectSpaceVersion": null,

    "Restart": false,
    "RestartDelaySeconds": 10,

    "AbortOnError": true,
    "AbortOnWarning": false,

    "OutputFile": "%Options::General.OutputDir%\\service-output-%projectName%-%timestamp%-%hash%.json",

    "UserFields": {
      "InputA": "InputA",
      "InputB": "InputB"
    },
    "OptionOverrides": {
      "OptionA": "ValueA",
      "OptionB": "ValueB"
    }
  }
}
