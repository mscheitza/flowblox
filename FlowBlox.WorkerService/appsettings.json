{
  "FlowBloxService": {
    "ServiceName": "FlowBlox.Service",
    "DisplayName": "FlowBlox Project Service",
    "Description": "Executes a FlowBlox project in the background using FlowBlox.Core.Runner.",
    "RunOnStart": true,

    "ProjectFile": "C:\\FlowBlox\\Projects\\MyProject.fbprj",
    "NoDesignerMode": true,

    "Restart": false,
    "RestartDelaySeconds": 10,

    "AbortOnError": true,
    "AbortOnWarning": false,

    "OutputFile": "C:\\FlowBlox\\service-output.json",

    "UserFields": {
      "InputA": "InputA",
      "InputB": "InputB"
    },
    "OptionOverrides": {
      "OptionA": "ValueA",
      "OptionB": "ValueB"
    }
  }
}